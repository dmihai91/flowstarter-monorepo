# ============================================
# SHARED ENVIRONMENT VARIABLES (EXAMPLE)
# ============================================
# Copy this to .env.shared and fill in real values.
# These variables are shared across all apps in the monorepo.
# ============================================

# --------------------------------------------
# CLERK AUTHENTICATION
# --------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Cookie domain for cross-subdomain auth
# Dev: .flowstarter.dev | Prod: .flowstarter.app | Local: leave empty
# CLERK_COOKIE_DOMAIN=.flowstarter.app

# --------------------------------------------
# SUPABASE
# --------------------------------------------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx

# --------------------------------------------
# INTER-APP COMMUNICATION
# --------------------------------------------
SHARED_APP_SECRET=your-secret-here

# --------------------------------------------
# PLATFORM URLs
# --------------------------------------------
MAIN_PLATFORM_URL=http://localhost:3000
EDITOR_URL=http://localhost:5175
