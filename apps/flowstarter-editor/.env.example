# shellcheck disable=SC2034,SC2148

# Rename this file to .env once you have filled in the below environment variables!

# =============================================================================
# REQUIRED: AI Provider API Keys
# =============================================================================

# OpenRouter API Key - https://openrouter.ai/settings/keys
# OpenRouter provides unified access to 100+ AI models (Claude, GPT, DeepSeek, etc.)
# Used as the primary provider for model selection in the editor
OPEN_ROUTER_API_KEY=

# Anthropic API Key - https://console.anthropic.com/settings/keys
# Direct access to Claude models for the Anthropic SDK
# Used by the Claude Agent SDK for orchestration tasks
ANTHROPIC_API_KEY=

# Groq API Key - https://console.groq.com/keys
# Ultra-fast inference for quick tasks like onboarding chat
# Falls back to OpenRouter if not configured
GROQ_API_KEY=

# =============================================================================
# REQUIRED: Convex Configuration (Real-time Backend)
# =============================================================================
# Convex provides real-time database, state management, and serverless functions
#
# For local development:
#   1. Run `npx convex dev` to start a local Convex server
#   2. The URL will be automatically set in .env.local
#
# For production:
#   Use your deployed Convex URL from https://dashboard.convex.dev
VITE_CONVEX_URL=http://127.0.0.1:3210

# =============================================================================
# OPTIONAL: GitHub Integration
# =============================================================================
# Get your GitHub Personal Access Token here - https://github.com/settings/tokens
# This token is used for:
# 1. Importing/cloning GitHub repositories without rate limiting
# 2. Accessing private repositories
# 3. Automatic GitHub authentication (no need to manually connect in the UI)
#
# For classic tokens, ensure it has these scopes: repo, read:org, read:user
# For fine-grained tokens, ensure it has Repository and Organization access
VITE_GITHUB_ACCESS_TOKEN=

# Specify the type of GitHub token you're using
# Can be 'classic' or 'fine-grained'
# Classic tokens are recommended for broader access
VITE_GITHUB_TOKEN_TYPE=classic

# =============================================================================
# OPTIONAL: Flowstarter MCP Server
# =============================================================================
# Run the flowstarter-library MCP server from the companion project
# cd D:\Projects\flowstarter\flowstarter-library\mcp-server && pnpm dev
VITE_FLOWSTARTER_MCP_URL=http://localhost:3001

# =============================================================================
# OPTIONAL: Daytona Sandbox (Preview Rendering)
# =============================================================================
# Daytona provides sandbox environments for running dev servers
# Get your API key from https://app.daytona.io
# Used for the Monaco + Daytona editor mode to render live previews
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# =============================================================================
# OPTIONAL: Debug & Logging
# =============================================================================
# Include this environment variable if you want more logging for debugging locally
# Options: debug, info, warn, error
VITE_LOG_LEVEL=debug

# =============================================================================
# OPTIONAL: Main Platform Integration (Handoff)
# =============================================================================
# For receiving users from the main Flowstarter platform with prefilled project data

# Main platform URL for validating handoff tokens
MAIN_PLATFORM_URL=http://localhost:3000

# Handoff secret for secure cross-app communication (must match main platform)
# Can also use TOKEN_ENCRYPTION_KEY
HANDOFF_SECRET=

# =============================================================================
# OPTIONAL: Tavily Search API (for FlowOps SearchTool)
# =============================================================================
# Tavily provides AI-optimized search for the self-healing system
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=

# =============================================================================
# OPTIONAL: LangSmith Tracing (for Claude Code)
# =============================================================================
# These variables enable OpenTelemetry tracing to LangSmith for monitoring Claude Code operations
# Get your LangSmith API Key from https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=claude-code-trace

# Claude Code Telemetry (set to 1 to enable)
CLAUDE_CODE_ENABLE_TELEMETRY=

# OpenTelemetry Configuration (uncomment to enable)
# OTEL_LOGS_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_LOGS_PROTOCOL=http/json
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=https://api.smith.langchain.com/otel/v1/claude_code
# OTEL_LOG_USER_PROMPTS=1

# Clerk Authentication (for team login)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
