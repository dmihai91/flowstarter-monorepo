# E2E Test Environment Configuration
# Copy this file to .env.test and fill in your credentials

# =============================================================================
# REQUIRED: AI Provider API Keys (at least one required for E2E tests)
# =============================================================================

# OpenRouter API Key - https://openrouter.ai/settings/keys
# Used for model selection and chat completions
OPEN_ROUTER_API_KEY=

# Groq API Key - https://console.groq.com/keys
# Used for fast inference in onboarding chat
GROQ_API_KEY=

# Anthropic API Key - https://console.anthropic.com/settings/keys
# Used by Claude Agent SDK
ANTHROPIC_API_KEY=

# =============================================================================
# REQUIRED: Convex Configuration
# =============================================================================
# For E2E tests, run `npx convex dev` in a separate terminal
VITE_CONVEX_URL=http://127.0.0.1:3210

# =============================================================================
# OPTIONAL: Daytona Configuration (for full preview tests)
# =============================================================================
# Get your API key from https://app.daytona.io
# Without this, preview-related tests will be skipped
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# =============================================================================
# OPTIONAL: MCP Server (for template tests)
# =============================================================================
VITE_FLOWSTARTER_MCP_URL=http://localhost:3001

# =============================================================================
# Test Configuration
# =============================================================================
VITE_LOG_LEVEL=debug
NODE_ENV=test
