{
  "name": "flowstarter-editor",
  "description": "AI-Powered Site Creation Platform",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "version": "1.2.3",
  "author": {
    "name": "Flowstarter",
    "email": "contact@flowstarter.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dmihai91/flowstarter.git"
  },
  "scripts": {
    "convex:dev": "pnpm exec convex dev",
    "convex:deploy": "convex deploy",
    "deploy": "npm run build",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 remix vite:build",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 node pre-start.cjs && remix vite:dev",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:all": "playwright test --test-match '**/*.spec.ts'",
    "test:e2e:smoke": "playwright test --test-match '**/smoke/*.spec.ts'",
    "test:e2e:integration": "playwright test --test-match '**/integration/*.spec.ts'",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:setup": "tsx scripts/setup-e2e.ts",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint app",
    "lint:fix": "npm run lint -- --fix && prettier app --write",
    "start": "tsx server.ts",
    "start:prod": "NODE_ENV=production tsx server.ts",
    "dockerstart": "NODE_ENV=production tsx server.ts",
    "dockerrun": "docker run -it -d --name flowstarter-editor -p 5173:5173 --env-file .env flowstarter-editor",
    "dockerbuild:prod": "docker build -t flowstarter-editor:production -t flowstarter-editor:latest --target flowstarter-production .",
    "dockerbuild": "docker build -t flowstarter-editor:development -t flowstarter-editor:latest --target flowstarter-development .",
    "typecheck": "tsc",
    "preview": "pnpm run build && pnpm run start:prod",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.15.1"
  },
