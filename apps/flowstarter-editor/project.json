{  
  "name": "flowstarter-editor",  
  "projectType": "application",  
  "tags": ["app:editor", "platform:railway"],  
  "targets": {  
    "build": {  
      "executor": "nx:run-commands",  
      "options": {  
        "command": "pnpm run build",  
        "cwd": "apps/flowstarter-editor"  
      }  
    },  
    "dev": {  
      "executor": "nx:run-commands",  
      "options": {  
        "command": "pnpm run dev",  
        "cwd": "apps/flowstarter-editor"  
      }  
    },  
    "lint": { "executor": "@nx/eslint:lint" },  
    "typecheck": {  
      "executor": "nx:run-commands",  
      "options": { "command": "tsc --noEmit", "cwd": "apps/flowstarter-editor" }  
    }  
  }  
}  
