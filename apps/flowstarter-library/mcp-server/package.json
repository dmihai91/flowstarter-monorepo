{
  "name": "@flowstarter/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Flowstarter Library - exposes templates to the AI-powered platform",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mcp-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:http": "tsc && node build/index.js --mode=http",
    "start": "node build/index.js",
    "start:http": "node build/index.js --mode=http",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "gen:thumbs": "node ../scripts/generate-theme-thumbnails.mjs",
    "deploy": "node scripts/deploy-all.js",
    "deploy:templates": "node scripts/deploy-all.js --templates",
    "deploy:showcase": "node scripts/deploy-all.js --showcase",
    "deploy:fast": "node scripts/deploy-all.js --parallel"
  },
  "keywords": ["mcp", "model-context-protocol", "flowstarter", "templates"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clerk/backend": "^2.27.0",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.17.10",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.15",
    "typescript": "~5.7.2",
    "vitest": "^4.0.15"
  }
}
