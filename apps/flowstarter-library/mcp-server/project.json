{
  "name": "@flowstarter/mcp-server",
  "projectType": "application",
  "tags": ["app:mcp-server", "platform:railway"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run build",
        "cwd": "apps/flowstarter-library/mcp-server"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run dev",
        "cwd": "apps/flowstarter-library/mcp-server"
      }
    },
    "dev:http": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run dev:http",
        "cwd": "apps/flowstarter-library/mcp-server"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run start",
        "cwd": "apps/flowstarter-library/mcp-server"
      }
    },
    "start:http": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run start:http",
        "cwd": "apps/flowstarter-library/mcp-server"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm test",
        "cwd": "apps/flowstarter-library/mcp-server"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/flowstarter-library/mcp-server"
      }
    }
  }
}
