{
  "name": "Academic Tutor",
  "slug": "academic-tutor",
  "description": "Professional template for academic tutors, test prep specialists, and subject matter experts. Features 1-on-1 session booking, student testimonials, and subject expertise showcase.",
  "category": "education",
  "tags": ["tutor", "academic", "test-prep", "SAT", "ACT", "math", "science", "english", "homework-help", "online-tutoring"],
  "framework": "astro",
  "features": ["Multi-page", "Booking integration", "Newsletter integration", "Subject showcase", "Testimonials", "Pricing packages"],
  "integrations": {
    "booking": {
      "name": "Booking System",
      "description": "Let students book tutoring sessions directly",
      "providers": [
        {"id": "calendly", "name": "Calendly", "field": "calendly_url", "placeholder": "https://calendly.com/your-username/tutoring-session"},
        {"id": "calcom", "name": "Cal.com", "field": "calcom_url", "placeholder": "https://cal.com/your-username/tutoring"}
      ],
      "optional": true,
      "configPath": "content/integrations/booking.md"
    },
    "newsletter": {
      "name": "Newsletter",
      "description": "Share study tips and resources with students",
      "providers": [
        {"id": "mailchimp", "name": "Mailchimp", "field": "mailchimp_url", "placeholder": "https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx"},
        {"id": "convertkit", "name": "ConvertKit", "field": "convertkit_form_id", "placeholder": "1234567"}
      ],
      "optional": true,
      "configPath": "content/integrations/newsletter.md"
    }
  }
}
