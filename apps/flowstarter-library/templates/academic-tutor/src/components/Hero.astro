---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_color-mix(in_srgb,var(--color-secondary)_85%,white)_0%,white_48%,var(--color-background)_100%)]"></div>
  <div class="relative mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="max-w-2xl">
      {badge && (
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border px-5 py-2 text-sm font-semibold backdrop-blur-xl" style="border-color: color-mix(in srgb, var(--color-primary) 16%, white); background: color-mix(in srgb, white 82%, var(--color-secondary) 18%); color: var(--color-primary);">
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
          <span>{badge}</span>
        </div>
      )}
      <h1 class="text-5xl font-black leading-tight text-[var(--color-text)] sm:text-6xl">{headline}</h1>
      {subheadline && (
        <p class="mt-6 max-w-xl text-lg leading-8 text-[color:var(--color-text-muted)]">{subheadline}</p>
      )}
      <div class="mt-8 flex flex-wrap gap-3">
        {['SAT Prep', 'Math', 'Science', 'Writing'].map((chip: string) => (
          <span class="rounded-full px-4 py-2 text-sm font-semibold" style="background: color-mix(in srgb, var(--color-primary) 10%, white); color: var(--color-primary);">
            {chip}
          </span>
        ))}
      </div>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        {cta_primary && (
          <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-white shadow-lg shadow-black/10" style="background: var(--color-primary);">
            {cta_primary.text}
          </a>
        )}
        {cta_secondary && (
          <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border px-7 py-4 text-sm font-semibold" style="border-color: color-mix(in srgb, var(--color-primary) 24%, white); color: var(--color-primary); background: white;">
            {cta_secondary.text}
          </a>
        )}
      </div>
    </div>
    <div class="relative">
      <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full opacity-80" style="background: color-mix(in srgb, var(--color-accent) 40%, white);"></div>
      <div class="rounded-[2.5rem] p-6 shadow-[0_25px_70px_rgba(26,58,107,0.18)]" style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 10%, white), color-mix(in srgb, var(--color-secondary) 80%, white));">
        <div class="relative aspect-[4/3] overflow-hidden rounded-[2rem] bg-[linear-gradient(135deg,rgba(255,255,255,0.95),rgba(238,243,251,0.85))]">
          <svg class="absolute inset-0 h-full w-full" viewBox="0 0 520 420" aria-hidden="true">
            <circle cx="388" cy="112" r="86" fill="rgba(232,64,64,0.18)"></circle>
            <path d="M95 290h176c18 0 33 15 33 33v15H62v-15c0-18 15-33 33-33z" fill="rgba(26,58,107,0.14)"></path>
            <rect x="86" y="86" width="228" height="168" rx="20" fill="rgba(26,58,107,0.08)"></rect>
            <path d="M142 188h118M142 218h86M352 238l40 40 76-90" stroke="rgba(26,58,107,0.72)" stroke-width="16" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
          </svg>
        </div>
      </div>
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        {stats.map((stat: HeroStat) => (
          <div class="rounded-2xl border border-white/75 bg-white/80 px-4 py-4 text-center shadow-md shadow-black/5 backdrop-blur-xl">
            <div class="text-2xl font-black text-[var(--color-primary)]">{stat.value}</div>
            <div class="mt-1 text-sm text-[color:var(--color-text-muted)]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
