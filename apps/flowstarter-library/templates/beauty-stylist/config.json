{
  "name": "Beauty Stylist",
  "slug": "beauty-stylist",
  "description": "Template for hairstylists, makeup artists, estheticians, and beauty professionals. Elegant rose and gold design with appointment booking and service gallery.",
  "category": "beauty",
  "tags": [
    "beauty",
    "hair-stylist",
    "makeup-artist",
    "esthetician",
    "salon",
    "bridal",
    "skincare"
  ],
  "framework": "astro",
  "features": [
    "Single-page",
    "Appointment booking",
    "Service gallery",
    "Testimonials",
    "FAQ accordion",
    "Dark mode"
  ],
  "integrations": {
    "booking": {
      "name": "Booking System",
      "description": "Connect Calendly to let clients book beauty appointments",
      "providers": [
        {
          "id": "calendly",
          "name": "Calendly",
          "field": "calendly_url",
          "placeholder": "https://calendly.com/your-username/appointment"
        },
        {
          "id": "calcom",
          "name": "Cal.com",
          "field": "calcom_url",
          "placeholder": "https://cal.com/your-username/appointment"
        }
      ],
      "optional": true,
      "configPath": "content/integrations/booking.md"
    },
    "newsletter": {
      "name": "Newsletter",
      "description": "Connect Mailchimp to collect beauty newsletter subscribers",
      "providers": [
        {
          "id": "mailchimp",
          "name": "Mailchimp",
          "field": "mailchimp_url",
          "placeholder": "https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx"
        },
        {
          "id": "convertkit",
          "name": "ConvertKit",
          "field": "convertkit_form_id",
          "placeholder": "1234567"
        },
        {
          "id": "buttondown",
          "name": "Buttondown",
          "field": "buttondown_username",
          "placeholder": "your-username"
        }
      ],
      "optional": true,
      "configPath": "content/integrations/newsletter.md"
    }
  },
  "fonts": [
    {
      "id": "font-1",
      "name": "Luxury",
      "heading": "Cormorant",
      "body": "Jost",
      "googleFonts": "Cormorant:ital,wght@0,300;0,600;1,300;1,600&family=Jost:wght@400;500"
    },
    {
      "id": "font-2",
      "name": "Editorial",
      "heading": "Playfair Display",
      "body": "Inter",
      "googleFonts": "Playfair+Display:wght@700&family=Inter:wght@400;500"
    },
    {
      "id": "font-3",
      "name": "Soft",
      "heading": "DM Serif Display",
      "body": "Nunito Sans",
      "googleFonts": "DM+Serif+Display:wght@400&family=Nunito+Sans:wght@400;600"
    },
    {
      "id": "font-4",
      "name": "Modern",
      "heading": "Prata",
      "body": "Manrope",
      "googleFonts": "Prata:wght@400&family=Manrope:wght@400;500"
    }
  ]
}
