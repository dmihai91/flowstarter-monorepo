---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-24 sm:px-6 lg:px-8">
  <div class="absolute inset-0 bg-[linear-gradient(180deg,#fff9fa_0%,#fbf5f7_100%)]"></div>
  <div class="relative mx-auto max-w-7xl">
    <div class="mb-10 flex items-center justify-between border-b border-black/8 pb-4 text-xs uppercase tracking-[0.28em] text-[color:var(--color-text-muted)]">
      <span>Atelier Beauty</span>
      <span>Editorial Styling</span>
    </div>
    <div class="grid items-start gap-12 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="max-w-2xl pt-6">
        {badge && (
          <div class="mb-6 inline-flex items-center gap-3 rounded-full border px-5 py-2 text-sm font-medium" style="border-color: color-mix(in srgb, var(--color-primary) 20%, white); background: rgba(255,255,255,0.78); color: var(--color-text);">
            <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
            <span>{badge}</span>
          </div>
        )}
        <h1 class="text-5xl font-light leading-[0.92] text-[var(--color-text)] sm:text-6xl lg:text-7xl" style="font-style: italic;">{headline}</h1>
        {subheadline && (
          <p class="mt-6 max-w-xl text-lg leading-8 text-[color:var(--color-text-muted)]">{subheadline}</p>
        )}
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          {cta_primary && (
            <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-white shadow-lg shadow-black/10" style="background: var(--color-primary);">{cta_primary.text}</a>
          )}
          {cta_secondary && (
            <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border px-7 py-4 text-sm font-semibold" style="border-color: color-mix(in srgb, var(--color-accent) 35%, white); color: var(--color-text); background: rgba(255,255,255,0.72);">{cta_secondary.text}</a>
          )}
        </div>
        <div class="mt-12 grid gap-4 sm:grid-cols-3">
          {stats.map((stat: HeroStat) => (
            <div class="rounded-2xl border border-white/70 bg-white/76 px-5 py-5 backdrop-blur-xl">
              <div class="text-3xl font-semibold text-[var(--color-text)]">{stat.value}</div>
              <div class="mt-1 text-sm text-[color:var(--color-text-muted)]">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="relative min-h-[34rem]">
        <div class="absolute right-6 top-0 h-[62%] w-[54%] rounded-[2.2rem] shadow-[0_30px_70px_rgba(0,0,0,0.16)]" style="background: linear-gradient(180deg, color-mix(in srgb, var(--color-primary) 22%, white), color-mix(in srgb, var(--color-accent) 26%, white));"></div>
        <div class="absolute left-0 top-20 h-[68%] w-[64%] rounded-[2.4rem] border border-white/60 bg-[linear-gradient(180deg,rgba(255,255,255,0.9),rgba(255,255,255,0.55))] shadow-[0_25px_60px_rgba(0,0,0,0.12)] backdrop-blur-md"></div>
        <div class="absolute bottom-8 right-0 w-[46%] rounded-[1.8rem] bg-white/82 px-5 py-5 shadow-xl shadow-black/10">
          <div class="text-sm uppercase tracking-[0.18em] text-[color:var(--color-text-muted)]">Signature</div>
          <div class="mt-2 text-2xl font-semibold text-[var(--color-text)]">Hair. Skin. Styling.</div>
        </div>
      </div>
    </div>
  </div>
</section>
