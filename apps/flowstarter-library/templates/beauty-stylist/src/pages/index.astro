---
import Layout from '../layouts/Layout.astro';


const _iconMap: Record<string, string> = {
  "lucide:droplet": `<path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>`,
  "lucide:eye": `<g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></g>`,
  "lucide:heart": `<path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>`,
  "lucide:palette": `<g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></g>`,
  "lucide:scissors": `<circle cx="12" cy="12" r="5" fill="currentColor"/>`,
  "lucide:sparkles": `<path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>`,
};
function getIconSvg(name: string, cls: string): string {
  const body = _iconMap[name] || '<circle cx="12" cy="12" r="5" fill="currentColor"/>';
  const needsFill = ["lucide:facebook","lucide:star","lucide:linkedin"].includes(name);
  const fill = needsFill ? "currentColor" : "none";
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="${fill}" class="${cls}" aria-hidden="true">${body}</svg>`;
}

interface Service {
  icon: string;
  title: string;
  description: string;
  price: string;
}

interface ProcessStep {
  title: string;
  description: string;
}

interface Testimonial {
  quote: string;
  author: string;
  type: string;
}

interface FAQ {
  question: string;
  answer: string;
}

const services: Service[] = [
  { icon: "lucide:scissors", title: "Hair Styling & Cuts", description: "Precision haircuts tailored to your face shape, lifestyle, and personal style. From classic bobs to modern textured cuts.", price: "$85–$150" },
  { icon: "lucide:palette", title: "Color & Highlights", description: "Expert balayage, ombré, highlights, and full color services using premium, low-damage formulas for vibrant, lasting results.", price: "$150–$350" },
  { icon: "lucide:heart", title: "Bridal & Events", description: "Complete bridal beauty packages including trial runs, day-of styling, and touch-up kits. Making your special day flawless.", price: "From $400" },
  { icon: "lucide:sparkles", title: "Makeup Artistry", description: "Editorial, bridal, and everyday makeup using top-tier products. Customized looks that enhance your natural beauty.", price: "$120" },
  { icon: "lucide:droplet", title: "Skincare Treatments", description: "Luxurious facials, chemical peels, and skin rejuvenation treatments for a radiant, healthy complexion.", price: "$95–$200" },
  { icon: "lucide:eye", title: "Lash & Brow Studio", description: "Lash extensions, lifts, brow shaping, tinting, and lamination for perfectly framed eyes.", price: "$65–$150" },
];

const process: ProcessStep[] = [
  { title: "Consultation", description: "We start with a detailed conversation about your vision, lifestyle, hair history, and goals to ensure the perfect result." },
  { title: "Personalization", description: "I analyze your features, skin tone, and personal style to create a customized plan tailored uniquely to you." },
  { title: "Precision", description: "Using premium products and expert techniques honed over years, I bring your vision to life with meticulous attention to detail." },
  { title: "Aftercare", description: "You leave with personalized care instructions and product recommendations to maintain your stunning results at home." },
];

const testimonials: Testimonial[] = [
  { quote: "Sophia did my wedding hair and makeup and I have never felt more beautiful. Every photo from that day is perfection. She knew exactly what I wanted before I could even explain it.", author: "Rachel T.", type: "Bridal Client" },
  { quote: "I came in after a terrible color job at another salon. Sophia not only corrected it but gave me the most gorgeous balayage I've ever had. She's a true color wizard.", author: "Michelle D.", type: "Color Correction Client" },
  { quote: "I've been coming to Sophia for three years now and she's the only person I trust with my hair. Every cut is exactly what I envision. She's boosted my confidence immensely.", author: "Lauren K.", type: "Regular Client" },
];

const faqs: FAQ[] = [
  { question: "What is your booking and cancellation policy?", answer: "I require a 50% deposit to secure your appointment. Cancellations made less than 24 hours before your appointment will forfeit the deposit. Bridal bookings require a non-refundable retainer." },
  { question: "Do you offer free consultations?", answer: "Yes! I offer complimentary 15-minute consultations for color services, bridal packages, and any service over $200. This helps us align on your vision and set expectations." },
  { question: "What products do you use?", answer: "I exclusively use professional, salon-grade products including Olaplex, Kevin Murphy, and Charlotte Tilbury. All products are cruelty-free and selected for quality and performance." },
  { question: "How far in advance should I book for bridal services?", answer: "I recommend booking bridal services 6-12 months in advance. This allows time for a thorough consultation, trial run, and any adjustments before your big day." },
  { question: "What should I bring to my appointment?", answer: "Bring inspiration photos of styles you love! For color appointments, come with unwashed hair. For bridal trials, bring your veil or accessories. Wear a button-down shirt for easy changing." },
];

const stats = [
  { value: "3,000+", label: "Happy Clients" },
  { value: "8", label: "Years Experience" },
  { value: "4.9", label: "Average Rating" },
  { value: "15+", label: "Industry Awards" },
];
---

<Layout>
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-warm-100 dark:from-slate-800/50 to-transparent opacity-50"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>
    
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-primary font-medium mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></g></svg>
            Award-Winning Stylist
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold text-slate-800 dark:text-white leading-tight mb-6">
            Elevate Your <span class="text-primary">Beauty</span>
          </h1>
          <p class="text-lg text-slate-600 dark:text-slate-400 mb-8 max-w-lg">
            I'm Sophia Chen, and with over 8 years of experience trained in Paris and New York, I blend artistry with expertise to create looks that are uniquely you.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="#contact" class="btn-primary">
              Book an Appointment
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 ml-2" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></g></svg>
            </a>
            <a href="#services" class="btn-outline">View Services</a>
          </div>
          <div class="grid grid-cols-4 gap-4">
            {stats.map((stat: { value: string; label: string }) => (
              <div class="text-center">
                <div class="text-2xl font-serif font-bold text-slate-800 dark:text-white">{stat.value}</div>
                <div class="text-xs text-slate-500 dark:text-slate-400">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
        
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-3xl transform rotate-3"></div>
          <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&h=700&fit=crop&crop=face" alt="Sophia Chen, Master Stylist" class="relative rounded-3xl shadow-xl w-full object-cover aspect-[5/6]" />
          <div class="absolute -bottom-6 -left-6 bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-primary" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></g></svg>
              </div>
              <div>
                <div class="text-2xl font-serif font-bold text-slate-800 dark:text-white">15+</div>
                <div class="text-sm text-slate-500 dark:text-slate-400">Awards Won</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 bg-warm-50 dark:bg-slate-800/50 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <div class="grid grid-cols-2 gap-4">
            <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=300&h=400&fit=crop" alt="Hair styling" class="rounded-2xl shadow-md w-full object-cover aspect-[3/4]" />
            <img src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=300&h=400&fit=crop" alt="Beauty studio" class="rounded-2xl shadow-md w-full object-cover aspect-[3/4] mt-8" />
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <p class="text-primary font-medium mb-4">About Me</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">
            Where Artistry Meets Expertise
          </h2>
          <p class="text-slate-600 dark:text-slate-400 mb-6">
            Trained at the prestigious Vidal Sassoon Academy in London and the Makeup Atelier in Paris, I've spent my career perfecting the art of beauty transformation.
          </p>
          <p class="text-slate-600 dark:text-slate-400 mb-8">
            I specialize in color, bridal beauty, and editorial styling. My work has been featured in Vogue, Harper's Bazaar, and Allure, and I've styled for New York Fashion Week four seasons running.
          </p>
          <ul class="space-y-3">
            {["Vidal Sassoon Academy Graduate, London", "Makeup Atelier Paris Certification", "Featured in Vogue & Harper's Bazaar", "15+ Industry Awards & Recognitions"].map((credential: string) => (
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-primary flex-shrink-0" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></g></svg>
                <span class="text-slate-700 dark:text-slate-300">{credential}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-20 bg-cream dark:bg-slate-900 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-primary font-medium mb-4">Services</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Beauty Services</h2>
        <p class="text-slate-600 dark:text-slate-400">From everyday elegance to show-stopping glamour, each service is crafted with precision and care.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service: Service) => (
          <div class="card group hover:-translate-y-1">
            <div class="w-14 h-14 bg-primary/10 dark:bg-primary/20 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-primary/20 dark:group-hover:bg-primary/30 transition-colors">
              <Fragment set:html={getIconSvg(service.icon, "w-7 h-7 text-primary")} />
            </div>
            <h3 class="text-xl font-serif font-semibold text-slate-800 dark:text-white mb-2">{service.title}</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-4">{service.description}</p>
            <span class="inline-flex items-center gap-2 text-sm text-primary font-medium">
              {service.price}
            </span>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="#contact" class="btn-primary">
          Book Your Appointment
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 ml-2" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M8 2v4M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></g></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Process / Gallery Section -->
  <section id="gallery" class="py-20 bg-warm-100 dark:bg-slate-800/50 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-primary font-medium mb-4">My Process</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">The Studio Aria Experience</h2>
        <p class="text-slate-600 dark:text-slate-400">Every visit is a luxurious, personalized experience designed to make you feel and look your absolute best.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {process.map((item: ProcessStep, index: number) => (
          <div class="flex gap-5">
            <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-serif font-bold flex-shrink-0">{index + 1}</div>
            <div>
              <h3 class="text-xl font-serif font-semibold text-slate-800 dark:text-white mb-2">{item.title}</h3>
              <p class="text-slate-600 dark:text-slate-400">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 bg-cream dark:bg-slate-900 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-primary font-medium mb-4">Testimonials</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Client Love</h2>
        <p class="text-slate-600 dark:text-slate-400">See why hundreds of clients trust Studio Aria for their most important beauty moments.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((testimonial: Testimonial) => (
          <div class="card-warm">
            <div class="mb-4"><Icon name="lucide:quote" class="w-10 h-10 text-primary/30" /></div>
            <p class="text-slate-700 dark:text-slate-300 mb-6 leading-relaxed italic">"{testimonial.quote}"</p>
            <div class="border-t border-warm-300 dark:border-slate-700 pt-4">
              <div class="font-semibold text-slate-800 dark:text-white">{testimonial.author}</div>
              <div class="text-sm text-slate-500 dark:text-slate-400">{testimonial.type}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-20 bg-warm-50 dark:bg-slate-800/50 transition-colors">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-primary font-medium mb-4">FAQ</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Common Questions</h2>
        <p class="text-slate-600 dark:text-slate-400">Everything you need to know before your visit to Studio Aria.</p>
      </div>

      <div class="space-y-4">
        {faqs.map((faq: FAQ, index: number) => (
          <div class="faq-item bg-white dark:bg-slate-800 rounded-xl shadow-sm dark:shadow-none dark:border dark:border-slate-700 overflow-hidden">
            <button class="faq-trigger w-full px-6 py-5 flex items-center justify-between text-left" data-index={index}>
              <span class="font-medium text-slate-800 dark:text-white pr-4">{faq.question}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-primary transition-transform faq-icon flex-shrink-0" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 dark:text-slate-400">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 bg-cream dark:bg-slate-900 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <p class="text-primary font-medium mb-4">Book Now</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Ready for Your Transformation?</h2>
          <p class="text-slate-600 dark:text-slate-400 mb-8">Book your appointment at Studio Aria and experience the art of personalized beauty. New clients receive a complimentary consultation.</p>

          <div class="space-y-6 mb-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 dark:bg-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-primary" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></g></svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-800 dark:text-white mb-1">Studio Location</h4>
                <p class="text-slate-600 dark:text-slate-400">156 W 44th Street, Suite 800<br>New York, NY 10036</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 dark:bg-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-primary" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></g></svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-800 dark:text-white mb-1">Studio Hours</h4>
                <p class="text-slate-600 dark:text-slate-400">Tuesday – Saturday: 9am – 7pm<br>Sunday – Monday: Closed</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 dark:bg-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-primary" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-800 dark:text-white mb-1">Contact</h4>
                <p class="text-slate-600 dark:text-slate-400">
                  <a href="tel:+12125550198" class="hover:text-primary transition-colors">(212) 555-0198</a><br>
                  <a href="mailto:hello@studioaria.com" class="hover:text-primary transition-colors">hello@studioaria.com</a>
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg dark:shadow-none dark:border dark:border-slate-700">
          <h3 class="text-xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Book an Appointment</h3>
          <form class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">First Name</label>
                <input type="text" class="input" placeholder="Your first name" />
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Last Name</label>
                <input type="text" class="input" placeholder="Your last name" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Email</label>
              <input type="email" class="input" placeholder="your@email.com" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Phone</label>
              <input type="tel" class="input" placeholder="(212) 555-0198" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">What service are you interested in?</label>
              <textarea rows="4" class="textarea" placeholder="Tell us about the look you're going for and any special occasions..."></textarea>
            </div>
            <button type="submit" class="btn-primary w-full">
              Request Appointment
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 ml-2" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></g></svg>
            </button>
            <p class="text-xs text-slate-500 dark:text-slate-400 text-center">We'll confirm your appointment within 24 hours.</p>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = trigger.querySelector('.faq-icon');
      
      document.querySelectorAll('.faq-item').forEach(otherItem => {
        if (otherItem !== item) {
          otherItem.querySelector('.faq-content')?.classList.add('hidden');
          otherItem.querySelector('.faq-icon')?.classList.remove('rotate-180');
        }
      });
      
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
