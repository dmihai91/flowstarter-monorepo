{
  "name": "Coach Pro",
  "slug": "coach-pro",
  "description": "Professional template for life coaches, business coaches, and executive coaches. Transformation-focused design with booking calendar, coaching packages, and client success stories.",
  "category": "coaching",
  "tags": ["coach", "life-coach", "business-coach", "career-coach", "executive-coach", "transformation", "professional"],
  "framework": "astro",
  "features": ["Multi-page", "Booking integration", "Newsletter integration", "Coaching packages", "Testimonials", "FAQ", "Dark mode"],
  "integrations": {
    "booking": {
      "name": "Booking System",
      "description": "Connect Calendly to let clients book coaching sessions",
      "providers": [
        {"id": "calendly", "name": "Calendly", "field": "calendly_url", "placeholder": "https://calendly.com/your-username/discovery-call"},
        {"id": "calcom", "name": "Cal.com", "field": "calcom_url", "placeholder": "https://cal.com/your-username/discovery-call"}
      ],
      "optional": true,
      "configPath": "content/integrations/booking.md"
    },
    "newsletter": {
      "name": "Newsletter",
      "description": "Connect Mailchimp to share coaching insights with subscribers",
      "providers": [
        {"id": "mailchimp", "name": "Mailchimp", "field": "mailchimp_url", "placeholder": "https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx"},
        {"id": "convertkit", "name": "ConvertKit", "field": "convertkit_form_id", "placeholder": "1234567"},
        {"id": "buttondown", "name": "Buttondown", "field": "buttondown_username", "placeholder": "your-username"}
      ],
      "optional": true,
      "configPath": "content/integrations/newsletter.md"
    }
  }
}
