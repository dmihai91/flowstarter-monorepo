---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_color-mix(in_srgb,var(--color-accent)_18%,white)_0%,white_45%,var(--color-background)_100%)]"></div>
  <div class="absolute right-0 top-10 hidden h-[32rem] w-[32rem] rounded-full blur-3xl lg:block" style="background: color-mix(in srgb, var(--color-accent) 18%, transparent);"></div>
  <div class="relative mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="max-w-2xl">
      {badge && (
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border px-5 py-2 text-sm font-medium backdrop-blur-xl" style="border-color: color-mix(in srgb, var(--color-primary) 18%, white); background: color-mix(in srgb, white 72%, var(--color-secondary) 28%); color: var(--color-text);">
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
          <span>{badge}</span>
        </div>
      )}
      <h1 class="text-5xl font-black leading-[0.92] text-[var(--color-text)] sm:text-6xl lg:text-7xl">
        {headline}
      </h1>
      {subheadline && (
        <p class="mt-6 max-w-xl text-lg leading-8 text-[color:var(--color-text-muted)]">
          {subheadline}
        </p>
      )}
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        {cta_primary && (
          <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-white shadow-xl shadow-black/10 transition-transform duration-300 hover:-translate-y-0.5" style="background: var(--color-primary);">
            {cta_primary.text}
          </a>
        )}
        {cta_secondary && (
          <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border px-7 py-4 text-sm font-semibold" style="border-color: color-mix(in srgb, var(--color-primary) 28%, white); color: var(--color-primary); background: white;">
            {cta_secondary.text}
          </a>
        )}
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        {stats.map((stat: HeroStat) => (
          <div class="rounded-2xl border border-white/60 bg-white/70 px-4 py-4 shadow-lg shadow-black/5 backdrop-blur-xl">
            <div class="text-2xl font-bold text-[var(--color-text)]">{stat.value}</div>
            <div class="mt-1 text-sm text-[color:var(--color-text-muted)]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
    <div class="relative">
      <div class="absolute inset-6 rounded-[2rem] border-[14px]" style="border-color: color-mix(in srgb, var(--color-accent) 80%, white);"></div>
      <div class="relative overflow-hidden rounded-[2.5rem] border border-white/50 bg-[linear-gradient(145deg,color-mix(in_srgb,var(--color-primary)_88%,white)_0%,color-mix(in_srgb,var(--color-primary)_58%,black)_100%)] p-6 shadow-[0_30px_80px_rgba(0,0,0,0.18)]">
        <div class="aspect-[4/5] rounded-[2rem] bg-[radial-gradient(circle_at_50%_26%,rgba(255,255,255,0.85),rgba(255,255,255,0.1)_26%,transparent_27%),linear-gradient(180deg,rgba(255,255,255,0.15),rgba(0,0,0,0.15))]"></div>
        <svg class="absolute inset-0 h-full w-full" viewBox="0 0 480 600" aria-hidden="true">
          <circle cx="250" cy="190" r="88" fill="rgba(255,255,255,0.88)"></circle>
          <path d="M160 472c18-88 72-134 154-134s136 46 154 134" fill="rgba(255,255,255,0.74)"></path>
          <path d="M186 150c16-62 62-96 126-96 46 0 82 16 108 48-10 36-34 60-72 72-68 21-120 32-162 34z" fill="rgba(232,168,56,0.55)"></path>
        </svg>
      </div>
    </div>
  </div>
</section>
