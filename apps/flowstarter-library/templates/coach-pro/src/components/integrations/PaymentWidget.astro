---
/**
 * Payment Widget Integration
 * Reads content from content/integrations/payments.md
 * Shows real payment form when enabled, beautiful placeholder when not
 */
import { getEntry } from 'astro:content';

type Props = {
  planName?: string;
  planPrice?: number;
}

const { planName = "Selected Plan", planPrice = 99 } = Astro.props;

const payments = await getEntry('integrations', 'payments');
const { 
  enabled,
  title,
  description,
  card_label,
  card_placeholder,
  expiry_label,
  expiry_placeholder,
  cvc_label,
  cvc_placeholder,
  name_label,
  name_placeholder,
  pay_button,
  processing_text,
  trust_badges,
  summary_title,
  subtotal_label,
  tax_label,
  total_label,
  success,
  error
} = payments.data;
---

<div class="payment-widget max-w-md mx-auto">
  <div class="bg-background rounded-2xl shadow-xl overflow-hidden border border-gray-100">
    
    <!-- Header -->
    <div class="p-6 border-b border-gray-100">
      <h3 class="text-xl font-heading font-bold text-text">{title}</h3>
      <p class="text-sm text-text-muted mt-1">{description}</p>
    </div>
    
    <!-- Order Summary -->
    <div class="p-6 bg-gray-50 border-b border-gray-100">
      <h4 class="text-sm font-medium text-text-muted uppercase tracking-wide mb-4">
        {summary_title}
      </h4>
      <div class="space-y-2">
        <div class="flex justify-between">
          <span class="text-text">{planName}</span>
          <span class="text-text">${planPrice}/mo</span>
        </div>
        <div class="flex justify-between text-text-muted">
          <span>{subtotal_label}</span>
          <span>${planPrice}</span>
        </div>
        <div class="flex justify-between text-text-muted">
          <span>{tax_label}</span>
          <span>$0</span>
        </div>
        <div class="border-t border-gray-200 pt-2 mt-2">
          <div class="flex justify-between font-semibold text-text">
            <span>{total_label}</span>
            <span>${planPrice}/mo</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Payment Form -->
    <form class="p-6 space-y-4">
      <!-- Card Number -->
      <div>
        <label class="block text-sm font-medium text-text mb-2">
          {card_label}
        </label>
        <div class="relative">
          <input
            type="text"
            placeholder={card_placeholder}
            class="input pl-12"
            maxlength="19"
          />
          <div class="absolute left-4 top-1/2 -translate-y-1/2">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
            </svg>
          </div>
        </div>
      </div>
      
      <!-- Expiry and CVC -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text mb-2">
            {expiry_label}
          </label>
          <input
            type="text"
            placeholder={expiry_placeholder}
            class="input"
            maxlength="5"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-2">
            {cvc_label}
          </label>
          <input
            type="text"
            placeholder={cvc_placeholder}
            class="input"
            maxlength="4"
          />
        </div>
      </div>
      
      <!-- Name on Card -->
      <div>
        <label class="block text-sm font-medium text-text mb-2">
          {name_label}
        </label>
        <input
          type="text"
          placeholder={name_placeholder}
          class="input"
        />
      </div>
      
      <!-- Submit Button -->
      <button type="submit" class="btn-primary w-full mt-6">
        <span class="pay-text">{pay_button}</span>
        <span class="processing-text hidden">{processing_text}</span>
      </button>
    </form>
    
    <!-- Trust Badges -->
    <div class="px-6 pb-6">
      <div class="flex items-center justify-center gap-6 pt-4 border-t border-gray-100">
        {trust_badges.map((badge) => (
          <div class="flex items-center gap-2 text-text-muted text-xs">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <span>{badge.text}</span>
          </div>
        ))}
      </div>
    </div>
    
  </div>
</div>

<style>
  .input {
    @apply w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors;
  }
  
  .btn-primary {
    @apply flex items-center justify-center px-8 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-colors;
  }
</style>

<script>
  // Payment form handling (placeholder - connects to Stripe in production)
  const form = document.querySelector('.payment-widget form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    btn?.classList.add('opacity-75', 'cursor-wait');
    btn?.querySelector('.pay-text')?.classList.add('hidden');
    btn?.querySelector('.processing-text')?.classList.remove('hidden');
    
    // Simulate processing
    setTimeout(() => {
      alert('Payment successful! In production, this connects to Stripe.');
      btn?.classList.remove('opacity-75', 'cursor-wait');
      btn?.querySelector('.pay-text')?.classList.remove('hidden');
      btn?.querySelector('.processing-text')?.classList.add('hidden');
    }, 2000);
  });
</script>
