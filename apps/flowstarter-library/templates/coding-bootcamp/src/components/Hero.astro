---
/**
 * Hero Component
 * Reads content from content/hero.md (frontmatter)
 */

// Import frontmatter from markdown
import { frontmatter as hero } from '../../content/hero.md';

const { headline, subheadline, badge, cta_primary, cta_secondary, stats } = hero;
---

<section class="hero relative pt-32 pb-20 md:pt-40 md:pb-32 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary to-primary-dark"></div>
  <div class="absolute inset-0 bg-[url('/images/hero-pattern.svg')] opacity-10"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Trust badge -->
    {badge && (
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white mb-8">
        <span class="text-yellow-400">★</span>
        <span class="text-sm font-medium">{badge}</span>
      </div>
    )}

    <!-- Main headline -->
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-white leading-tight mb-6">
      {headline}
    </h1>
    
    <!-- Subheadline -->
    {subheadline && (
      <p class="text-lg md:text-xl text-white/80 max-w-3xl mx-auto mb-10">
        {subheadline}
      </p>
    )}

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      {cta_primary && (
        <a href={cta_primary.href} class="btn-primary">
          {cta_primary.text}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      )}
      {cta_secondary && (
        <a href={cta_secondary.href} class="btn-secondary">
          {cta_secondary.text}
        </a>
      )}
    </div>

    <!-- Stats -->
    {stats && stats.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-3xl mx-auto">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-heading font-bold text-white mb-1">
              {stat.value}
            </div>
            <div class="text-white/60 text-sm">{stat.label}</div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .btn-primary {
    @apply inline-flex items-center px-8 py-4 bg-white text-primary font-semibold rounded-xl hover:bg-white/90 transition-all shadow-lg shadow-black/20;
  }
  
  .btn-secondary {
    @apply inline-flex items-center px-8 py-4 border-2 border-white text-white font-semibold rounded-xl hover:bg-white/10 transition-all;
  }
</style>
