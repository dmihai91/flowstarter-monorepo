---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8" style="background: linear-gradient(180deg, var(--color-background) 0%, color-mix(in srgb, var(--color-secondary) 82%, black) 100%);">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(0,212,255,0.22),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(123,47,190,0.24),transparent_24%)]"></div>
  <div class="relative mx-auto grid max-w-7xl items-center gap-16 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="max-w-2xl">
      <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-4 py-2 text-sm font-medium text-emerald-300 backdrop-blur-xl">
        <span class="h-2.5 w-2.5 rounded-full bg-emerald-400 shadow-[0_0_16px_rgba(74,222,128,0.85)]"></span>
        <span>LIVE ONLINE COHORT</span>
      </div>
      {badge && (
        <div class="mb-4 text-sm font-medium uppercase tracking-[0.18em] text-white/55">{badge}</div>
      )}
      <h1 class="text-5xl font-bold leading-[0.95] sm:text-6xl lg:text-7xl" style="background: linear-gradient(90deg, var(--color-primary), white 60%); -webkit-background-clip: text; color: transparent;">
        {headline}
      </h1>
      {subheadline && (
        <p class="mt-6 max-w-xl text-lg leading-8 text-white/72">{subheadline}</p>
      )}
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        {cta_primary && (
          <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-[var(--color-background)] shadow-[0_0_40px_rgba(0,212,255,0.28)]" style="background: var(--color-primary);">
            {cta_primary.text}
          </a>
        )}
        {cta_secondary && (
          <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border border-white/20 px-7 py-4 text-sm font-semibold text-white/90">
            {cta_secondary.text}
          </a>
        )}
      </div>
      <div class="mt-10 flex flex-wrap gap-4">
        {stats.map((stat: HeroStat) => (
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 backdrop-blur-xl">
            <div class="font-mono text-2xl font-bold text-[var(--color-primary)]">{stat.value}</div>
            <div class="mt-1 text-sm font-mono text-white/55">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
    <div class="rounded-[2rem] border border-white/10 bg-[#071120] p-4 shadow-[0_30px_90px_rgba(0,0,0,0.45)]">
      <div class="flex items-center gap-2 border-b border-white/10 px-2 pb-3">
        <span class="h-3 w-3 rounded-full bg-rose-400"></span>
        <span class="h-3 w-3 rounded-full bg-amber-300"></span>
        <span class="h-3 w-3 rounded-full bg-emerald-400"></span>
        <span class="ml-3 font-mono text-xs text-white/45">/src/cohort/outcomes.ts</span>
      </div>
      <div class="space-y-4 p-4 font-mono text-sm text-white/70">
        <div><span class="text-cyan-300">const</span> <span class="text-white">outcomes</span> = &#123;</div>
        <div class="pl-6"><span class="text-violet-300">hiringRate</span>: <span class="text-emerald-300">"94%"</span>,</div>
        <div class="pl-6"><span class="text-violet-300">careerSupport</span>: <span class="text-emerald-300">"1:1 mentorship"</span>,</div>
        <div class="pl-6"><span class="text-violet-300">stack</span>: [<span class="text-emerald-300">"React"</span>, <span class="text-emerald-300">"Node"</span>, <span class="text-emerald-300">"AI"</span>],</div>
        <div>&#125;;</div>
        <div class="rounded-2xl border border-cyan-400/25 bg-cyan-400/8 p-4">
          <div class="text-cyan-300">$ npm run launch-career</div>
          <div class="mt-2 text-white/70">Matching with hiring partners...</div>
          <div class="mt-1 text-emerald-300">Status: ready for interviews.</div>
        </div>
      </div>
    </div>
  </div>
</section>
