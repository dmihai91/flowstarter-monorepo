{
  "name": "Creative Portfolio",
  "slug": "creative-portfolio",
  "description": "Template for photographers, designers, videographers, and creative freelancers. Bold monochrome with amber accents, project inquiry form, and creative process showcase.",
  "category": "creative",
  "tags": [
    "photographer",
    "designer",
    "videographer",
    "creative",
    "portfolio",
    "freelancer",
    "brand-identity",
    "visual-design"
  ],
  "framework": "astro",
  "features": [
    "Single-page",
    "Project inquiry form",
    "Creative showcase",
    "Testimonials",
    "FAQ accordion",
    "Dark mode"
  ],
  "integrations": {
    "booking": {
      "name": "Booking System",
      "description": "Connect Calendly to let clients book creative consultations",
      "providers": [
        {
          "id": "calendly",
          "name": "Calendly",
          "field": "calendly_url",
          "placeholder": "https://calendly.com/your-username/project-call"
        },
        {
          "id": "calcom",
          "name": "Cal.com",
          "field": "calcom_url",
          "placeholder": "https://cal.com/your-username/project-call"
        }
      ],
      "optional": true,
      "configPath": "content/integrations/booking.md"
    },
    "newsletter": {
      "name": "Newsletter",
      "description": "Connect Mailchimp to collect creative newsletter subscribers",
      "providers": [
        {
          "id": "mailchimp",
          "name": "Mailchimp",
          "field": "mailchimp_url",
          "placeholder": "https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx"
        },
        {
          "id": "convertkit",
          "name": "ConvertKit",
          "field": "convertkit_form_id",
          "placeholder": "1234567"
        },
        {
          "id": "buttondown",
          "name": "Buttondown",
          "field": "buttondown_username",
          "placeholder": "your-username"
        }
      ],
      "optional": true,
      "configPath": "content/integrations/newsletter.md"
    }
  },
  "fonts": [
    {
      "id": "font-1",
      "name": "Poster",
      "heading": "Bebas Neue",
      "body": "Inter",
      "googleFonts": "Bebas+Neue:wght@400&family=Inter:wght@400;500"
    },
    {
      "id": "font-2",
      "name": "Studio",
      "heading": "Oswald",
      "body": "DM Sans",
      "googleFonts": "Oswald:wght@500;700&family=DM+Sans:wght@400;500"
    },
    {
      "id": "font-3",
      "name": "Editorial",
      "heading": "Playfair Display",
      "body": "Source Sans 3",
      "googleFonts": "Playfair+Display:wght@700&family=Source+Sans+3:wght@400;600"
    },
    {
      "id": "font-4",
      "name": "Sharp",
      "heading": "Anton",
      "body": "Space Grotesk",
      "googleFonts": "Anton:wght@400&family=Space+Grotesk:wght@400;500"
    }
  ]
}
