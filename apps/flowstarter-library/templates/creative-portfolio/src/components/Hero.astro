---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8" style="background: linear-gradient(180deg, var(--color-background) 0%, color-mix(in srgb, var(--color-secondary) 90%, black) 100%);">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,69,0,0.18),transparent_28%)]"></div>
  <div class="relative mx-auto max-w-7xl">
    {badge && (
      <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-5 py-2 text-sm font-medium text-white/72 backdrop-blur-xl">
        <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-primary)]"></span>
        <span>{badge}</span>
      </div>
    )}
    <h1 class="max-w-5xl text-6xl leading-[0.86] text-[var(--color-surface)] sm:text-7xl lg:text-[6.2rem]">
      I MAKE BRANDS <span style="color: var(--color-primary);">PEOPLE REMEMBER</span>
    </h1>
    {subheadline && (
      <p class="mt-8 max-w-3xl text-lg leading-8 text-white/70">{subheadline}</p>
    )}
    <div class="mt-10 flex flex-col gap-4 sm:flex-row">
      {cta_primary && (
        <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-[var(--color-background)]" style="background: var(--color-primary);">{cta_primary.text}</a>
      )}
      {cta_secondary && (
        <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border border-white/16 px-7 py-4 text-sm font-semibold text-white">{cta_secondary.text}</a>
      )}
    </div>
    <div class="mt-14 grid gap-4 md:grid-cols-3">
      {stats.map((stat: HeroStat) => (
        <div class="rounded-2xl border border-white/10 bg-white/5 px-5 py-5 backdrop-blur-xl">
          <div class="text-4xl leading-none text-[var(--color-primary)]">{stat.value}</div>
          <div class="mt-2 text-sm uppercase tracking-[0.2em] text-white/50">{stat.label}</div>
        </div>
      ))}
    </div>
    <div class="mt-12 overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 py-5">
      <div class="flex min-w-max gap-4 px-5">
        {['Brand systems', 'Campaign films', 'Packaging', 'Photography', 'Art direction', 'Launch assets'].map((item: string, index: number) => (
          <div class="w-56 flex-none rounded-[1.5rem] border border-white/10 px-5 py-6" style={`background: ${index % 2 === 0 ? 'rgba(255,69,0,0.12)' : 'rgba(255,255,255,0.04)'}`}>
            <div class="text-xs uppercase tracking-[0.18em] text-white/45">Preview {String(index + 1).padStart(2, '0')}</div>
            <div class="mt-3 text-2xl text-white">{item}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
