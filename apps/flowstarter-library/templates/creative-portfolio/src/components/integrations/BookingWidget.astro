---
import { frontmatter as bookingFrontmatter } from '../../../content/integrations/booking.md';
import Icon from '../Icon.astro';

interface TimeSlot {
  day: string;
  times: string[];
}

interface BookingField {
  name: string;
  label: string;
  type?: 'text' | 'email' | 'tel' | 'date' | 'datetime-local' | 'textarea';
  placeholder?: string;
  required?: boolean;
}

interface ConfirmationContent {
  title: string;
  message: string;
}

interface BookingData {
  enabled: boolean;
  provider?: string | null;
  calendly_url?: string;
  calcom_url?: string;
  title: string;
  description: string;
  cta: string;
  available_label?: string;
  timezone_label?: string;
  slots?: TimeSlot[];
  fields?: BookingField[];
  confirmation: ConfirmationContent;
}

const booking = bookingFrontmatter as BookingData;
const slots: TimeSlot[] = booking.slots ?? [];
const fields: BookingField[] = booking.fields ?? [];
const useCalendly: boolean = booking.enabled && booking.provider === 'calendly' && Boolean(booking.calendly_url);
const useCalcom: boolean = booking.enabled && booking.provider === 'calcom' && Boolean(booking.calcom_url);
const useShell: boolean = !useCalendly && !useCalcom;
---

<section id="booking" class="section-shell">
  <div class="section-heading">
    <span class="section-kicker">Booking</span>
    <h2 class="section-title">{booking.title}</h2>
    <p class="section-copy">{booking.description}</p>
  </div>

  {useCalendly && booking.calendly_url && (
    <div class="glass-card overflow-hidden p-3">
      <div class="calendly-inline-widget min-h-[700px] w-full rounded-[1.5rem] bg-white" data-url={booking.calendly_url}></div>
      <script src="https://assets.calendly.com/assets/external/widget.js" async></script>
    </div>
  )}

  {useCalcom && booking.calcom_url && (
    <div class="glass-card overflow-hidden p-3">
      <iframe
        src={booking.calcom_url}
        title={booking.title}
        class="min-h-[700px] w-full rounded-[1.5rem] bg-white"
        allow="camera; microphone"
      ></iframe>
    </div>
  )}

  {useShell && (
    <div class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <article class="glass-card p-6 sm:p-8">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--color-primary)]">{booking.available_label ?? 'Availability'}</p>
        {booking.timezone_label && <p class="mt-3 text-sm text-[var(--color-text-muted)]">{booking.timezone_label}</p>}
        <div class="mt-6 space-y-5">
          {slots.map((slot: TimeSlot) => (
            <div class="rounded-[1.25rem] border border-white/50 bg-white/45 p-4 backdrop-blur-sm">
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-text)]">{slot.day}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {slot.times.map((time: string) => (
                  <span class="inline-flex rounded-full bg-white/80 px-3 py-1 text-xs font-medium text-[var(--color-text)]">{time}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
        {!booking.enabled && (
          <p class="mt-6 text-sm leading-7 text-[var(--color-text-muted)]">
            This is a presentation shell. Submission and scheduling logic are connected separately through Supabase or a booking provider.
          </p>
        )}
      </article>

      <article class="glass-card p-6 sm:p-8">
        <form class="grid gap-5" data-enabled={booking.enabled} data-provider={booking.provider ?? 'none'}>
          {fields.map((field: BookingField) => (
            <label class="grid gap-2 text-sm font-medium text-[var(--color-text)]">
              <span>
                {field.label}
                {field.required && <span class="ml-1 text-[var(--color-primary)]">*</span>}
              </span>
              {field.type === 'textarea' ? (
                <textarea
                  name={field.name}
                  rows={5}
                  class="glass-input min-h-[140px] resize-y"
                  placeholder={field.placeholder ?? ''}
                  required={field.required}
                ></textarea>
              ) : (
                <input
                  type={field.type ?? 'text'}
                  name={field.name}
                  class="glass-input"
                  placeholder={field.placeholder ?? ''}
                  required={field.required}
                />
              )}
            </label>
          ))}

          <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-4 text-sm font-semibold text-white shadow-lg shadow-black/10" style="background: var(--color-primary);">
            <Icon name="calendar" class="h-4 w-4" />
            <span>{booking.cta}</span>
          </button>
        </form>

        <div class="mt-6 rounded-[1.25rem] border border-white/55 bg-white/50 p-5">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-primary)]">{booking.confirmation.title}</p>
          <p class="mt-3 text-sm leading-7 text-[var(--color-text-muted)]">{booking.confirmation.message}</p>
        </div>
      </article>
    </div>
  )}
</section>
