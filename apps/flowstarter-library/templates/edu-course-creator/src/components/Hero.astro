---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_color-mix(in_srgb,var(--color-primary)_18%,white)_0%,white_42%,var(--color-background)_100%)]"></div>
  <div class="relative mx-auto max-w-5xl text-center">
    {badge && (
      <div class="mx-auto mb-7 inline-flex items-center gap-3 rounded-full border px-5 py-2 text-sm font-semibold backdrop-blur-xl" style="border-color: color-mix(in srgb, var(--color-primary) 18%, white); background: color-mix(in srgb, white 80%, var(--color-secondary) 20%); color: var(--color-primary);">
        <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
        <span>{badge}</span>
      </div>
    )}
    <h1 class="mx-auto max-w-4xl text-5xl font-extrabold leading-[0.96] text-[var(--color-text)] sm:text-6xl lg:text-7xl">{headline}</h1>
    {subheadline && (
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-[color:var(--color-text-muted)]">{subheadline}</p>
    )}
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      {cta_primary && (
        <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-white shadow-lg shadow-black/10" style="background: var(--color-primary);">{cta_primary.text}</a>
      )}
      {cta_secondary && (
        <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border px-7 py-4 text-sm font-semibold" style="border-color: color-mix(in srgb, var(--color-primary) 24%, white); color: var(--color-primary); background: white;">{cta_secondary.text}</a>
      )}
    </div>
    <div class="relative mt-16 grid gap-5 md:grid-cols-3">
      {stats.map((stat: HeroStat, index: number) => (
        <div class={`rounded-3xl border border-white/60 bg-white/75 px-6 py-6 text-left shadow-[0_20px_40px_rgba(0,0,0,0.08)] backdrop-blur-xl ${index === 1 ? 'md:-translate-y-5' : ''} ${index === 2 ? 'md:translate-y-4' : ''}`}>
          <div class="text-sm font-semibold uppercase tracking-[0.2em] text-[color:var(--color-text-muted)]">{stat.label}</div>
          <div class="mt-3 text-4xl font-extrabold text-[var(--color-text)]">{stat.value}</div>
        </div>
      ))}
    </div>
  </div>
</section>
