{
  "name": "Fitness Trainer Pro",
  "slug": "fitness-coach",
  "description": "High-energy template for personal trainers and fitness coaches. Bold design with transformation gallery, training programs, booking system, and client results.",
  "category": "fitness",
  "tags": ["fitness", "personal-trainer", "gym", "trainer", "workout", "athletic", "yoga", "strength"],
  "framework": "astro",
  "features": ["Multi-page", "Booking integration", "Newsletter integration", "Testimonials", "Pricing", "FAQ", "Dark mode"],
  "integrations": {
    "booking": {
      "name": "Booking System",
      "description": "Connect Calendly to let clients book training sessions",
      "providers": [
        {"id": "calendly", "name": "Calendly", "field": "calendly_url", "placeholder": "https://calendly.com/your-username/session"},
        {"id": "calcom", "name": "Cal.com", "field": "calcom_url", "placeholder": "https://cal.com/your-username/session"}
      ],
      "optional": true,
      "configPath": "content/integrations/booking.md"
    },
    "newsletter": {
      "name": "Newsletter",
      "description": "Connect Mailchimp to share fitness tips and workout plans",
      "providers": [
        {"id": "mailchimp", "name": "Mailchimp", "field": "mailchimp_url", "placeholder": "https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx"},
        {"id": "convertkit", "name": "ConvertKit", "field": "convertkit_form_id", "placeholder": "1234567"},
        {"id": "buttondown", "name": "Buttondown", "field": "buttondown_username", "placeholder": "your-username"}
      ],
      "optional": true,
      "configPath": "content/integrations/newsletter.md"
    }
  }
}
