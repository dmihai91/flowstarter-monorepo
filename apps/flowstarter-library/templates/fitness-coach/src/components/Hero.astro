---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8" style="background: linear-gradient(135deg, var(--color-secondary) 0%, color-mix(in srgb, var(--color-secondary) 92%, black) 55%, var(--color-background) 100%);">
  <div class="absolute inset-0 opacity-90" style="background: linear-gradient(120deg, transparent 0%, transparent 48%, color-mix(in srgb, var(--color-primary) 78%, transparent) 48%, color-mix(in srgb, var(--color-accent) 82%, transparent) 62%, transparent 62%);"></div>
  <div class="relative mx-auto grid max-w-7xl gap-16 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="max-w-3xl">
      {badge && (
        <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-white/15 bg-white/10 px-5 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-white/80 backdrop-blur-xl">
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
          <span>{badge}</span>
        </div>
      )}
      <h1 class="text-6xl font-extrabold uppercase leading-[0.88] text-white sm:text-7xl lg:text-[5.5rem]">
        {headlineLines.map((line: string) => (
          <span class="block">{line}</span>
        ))}
      </h1>
      {subheadline && (
        <p class="mt-8 max-w-2xl text-lg leading-8 text-white/72">
          {subheadline}
        </p>
      )}
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        {cta_primary && (
          <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-none px-8 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-secondary)] transition-transform duration-300 hover:-translate-y-0.5" style="background: var(--color-accent);">
            {cta_primary.text}
          </a>
        )}
        {cta_secondary && (
          <a href={cta_secondary.href} class="inline-flex items-center justify-center border border-white/30 px-8 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-white" style="background: rgba(255,255,255,0.02);">
            {cta_secondary.text}
          </a>
        )}
      </div>
    </div>
    <div class="grid gap-4 lg:justify-self-end lg:pt-8">
      {stats.map((stat: HeroStat) => (
        <div class="min-w-[14rem] border border-white/10 bg-white/5 px-6 py-6 backdrop-blur-md">
          <div class="text-sm uppercase tracking-[0.24em] text-white/45">{stat.label}</div>
          <div class="mt-3 text-5xl font-extrabold text-white">{stat.value}</div>
        </div>
      ))}
    </div>
  </div>
</section>
