---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,107,107,0.28),transparent_32%),radial-gradient(circle_at_bottom_right,rgba(78,205,196,0.3),transparent_26%),linear-gradient(180deg,#fffdf9_0%,#fff8f0_100%)]"></div>
  <div class="absolute right-0 top-10 h-72 w-72 rounded-full blur-3xl" style="background: color-mix(in srgb, var(--color-primary) 20%, transparent);"></div>
  <div class="relative mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="max-w-2xl">
      {badge && (
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border px-5 py-2 text-sm font-semibold" style="border-color: color-mix(in srgb, var(--color-primary) 20%, white); background: color-mix(in srgb, var(--color-surface) 70%, transparent); color: var(--color-text);">
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
          <span>{badge}</span>
        </div>
      )}
      <h1 class="text-5xl font-extrabold leading-[0.95] text-[var(--color-text)] sm:text-6xl">
        <span class="mr-2">🇫🇷</span>
        <span class="mr-2">🇪🇸</span>
        <span>{headline}</span>
      </h1>
      {subheadline && (
        <p class="mt-6 max-w-xl text-lg leading-8 text-[color:var(--color-text-muted)]">{subheadline}</p>
      )}
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        {cta_primary && (
          <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-bold text-white shadow-lg shadow-black/10" style="background: var(--color-primary);">{cta_primary.text}</a>
        )}
        {cta_secondary && (
          <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border px-7 py-4 text-sm font-bold" style="border-color: color-mix(in srgb, var(--color-accent) 35%, white); color: var(--color-text); background: color-mix(in srgb, var(--color-surface) 75%, transparent);">{cta_secondary.text}</a>
        )}
      </div>
      <div class="mt-10 flex flex-wrap gap-4">
        {stats.map((stat: HeroStat) => (
          <div class="rounded-2xl border border-white/70 bg-white/70 px-4 py-4 shadow-md shadow-black/5 backdrop-blur-xl">
            <div class="text-2xl font-extrabold text-[var(--color-text)]">{stat.value}</div>
            <div class="mt-1 text-sm text-[color:var(--color-text-muted)]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
    <div class="relative min-h-[26rem]">
      {['French', 'Spanish', 'Italian', 'Portuguese', 'Beginner', 'Travel', 'Conversation', 'Exam Prep'].map((pill: string, index: number) => (
        <div
          class="absolute rounded-full border px-5 py-3 text-sm font-bold shadow-lg shadow-black/5"
          style={`left: ${[16, 44, 58, 10, 52, 22, 64, 30][index]}%; top: ${[12, 4, 28, 42, 54, 70, 78, 22][index]}%; background: ${index % 2 === 0 ? 'rgba(255,255,255,0.78)' : 'color-mix(in srgb, var(--color-accent) 24%, white)'}; border-color: color-mix(in srgb, var(--color-primary) 18%, white); color: var(--color-text); transform: rotate(${[-7, 6, -4, 8, -8, 5, -6, 4][index]}deg);`}
        >
          {pill}
        </div>
      ))}
      <div class="absolute inset-10 rounded-[3rem] border border-white/60 bg-white/25 backdrop-blur-md"></div>
    </div>
  </div>
</section>
