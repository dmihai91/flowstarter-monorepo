              </svg>
              <svg class="icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
              </svg>
            </button>
            <a href="tel:+15551234567" class="text-slate-600 dark:text-slate-300 hover:text-primary transition-colors text-sm flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-4 h-4"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233a14 14 0 0 0 6.392 6.384"/></svg>
              (555) 123-4567
            </a>
            <a href="#contact" class="px-5 py-2.5 bg-primary text-white text-sm font-medium rounded-full hover:bg-primary-dark transition-colors">
              Book a Session
            </a>
          </div>

          <!-- Mobile Actions -->
          <div class="flex items-center gap-2 lg:hidden">
            <button class="theme-toggle" id="theme-toggle-mobile" aria-label="Toggle dark mode">
              <svg class="icon-sun" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
              <svg class="icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
              </svg>
            </button>
            <button id="mobile-menu-btn" class="p-2 text-slate-700 dark:text-slate-300" aria-label="Toggle menu">
              <svg class="w-6 h-6 icon-menu" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
              <svg class="w-6 h-6 icon-close hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden lg:hidden bg-cream dark:bg-slate-900 border-t border-warm-200 dark:border-slate-800">
        <div class="px-4 py-6 space-y-4">
          {navLinks.map((link) => (
            <a href={link.href} class="block text-slate-600 dark:text-slate-300 hover:text-primary transition-colors">
              {link.label}
            </a>
          ))}
          <div class="pt-4 border-t border-warm-200 dark:border-slate-800 space-y-3">
            <a href="tel:+15551234567" class="flex items-center gap-2 text-slate-600 dark:text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-4 h-4"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233a14 14 0 0 0 6.392 6.384"/></svg>
              (555) 123-4567
            </a>
            <a href="#contact" class="block w-full text-center px-5 py-3 bg-primary text-white font-medium rounded-full">
              Book a Session
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-sage-50 dark:bg-slate-950 border-t border-warm-200 dark:border-slate-800 transition-colors">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
          <!-- Brand Column -->
          <div class="lg:col-span-2">
            <a href="#" class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-primary/10 dark:bg-primary/20 rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-primary"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8c0 5.5-4.78 10-10 10"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></g></svg>
              </div>
              <div>
                <span class="text-lg font-serif font-semibold text-slate-800 dark:text-white">Sophie Martin</span>
                <span class="text-sm text-slate-500 dark:text-slate-400 ml-2">TEFL</span>
              </div>
            </a>
            <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-sm">
              Providing compassionate, evidence-based therapy to help you find peace, 
              build healthier relationships, and live a more fulfilling life.
            </p>
            <div class="flex gap-4">
              <a href="#" class="w-10 h-10 bg-white dark:bg-slate-800 rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-primary hover:text-white transition-all shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="w-5 h-5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
              <a href="#" class="w-10 h-10 bg-white dark:bg-slate-800 rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-primary hover:text-white transition-all shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8A4 4 0 0 1 16 11.37m1.5-4.87h.01"/></g></svg>
              </a>
              <a href="#" class="w-10 h-10 bg-white dark:bg-slate-800 rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-primary hover:text-white transition-all shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="w-5 h-5"><g><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2a2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6M2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></g></svg>
              </a>
            </div>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="font-serif font-semibold text-slate-800 dark:text-white mb-4">Quick Links</h4>
            <ul class="space-y-3">
              <li><a href="#about" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">About Me</a></li>
              <li><a href="#services" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">Services</a></li>
              <li><a href="#approach" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">My Approach</a></li>
              <li><a href="#faq" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">FAQ</a></li>
              <li><a href="#contact" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Contact Info -->
          <div>
            <h4 class="font-serif font-semibold text-slate-800 dark:text-white mb-4">Contact</h4>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></g></svg>
                <span class="text-slate-600 dark:text-slate-400">123 Wellness Way<br>Suite 200<br>San Francisco, CA 94102</span>
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-primary"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233a14 14 0 0 0 6.392 6.384"/></svg>
                <a href="tel:+15551234567" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">(555) 123-4567</a>
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-primary"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="m22 7l-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/><rect width="20" height="16" x="2" y="4" rx="2"/></g></svg>
                <a href="mailto:sarah@therapywellness.com" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">sarah@therapywellness.com</a>
              </li>
            </ul>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-warm-200 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-slate-500 dark:text-slate-500 text-sm">
            &copy; {new Date().getFullYear()} Sophie Martin Languages. All rights reserved.
          </p>
          <div class="flex items-center gap-6 text-sm text-slate-500">
            <a href="#" class="hover:text-primary transition-colors">Privacy Policy</a>
            <a href="#" class="hover:text-primary transition-colors">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Dark mode toggle
      function toggleTheme() {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      }
      document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
      document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

      // Mobile menu
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = mobileMenuBtn?.querySelector('.icon-menu');
      const closeIcon = mobileMenuBtn?.querySelector('.icon-close');

      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        menuIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
      });

      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        });
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth >= 1024) {
          mobileMenu?.classList.add('hidden');
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        }
      });
    </script>
    <ContactScript
      actionUrl={contactFormActionUrl}
      successMessage={contactFormSuccessMessage}
      templateName="language-teacher"
    />
  
    <!-- ═══ Booking Modal (injected by FlowStarter) ═══ -->
    <div id="fs-booking-modal" class="fixed inset-0 z-[200] hidden items-center justify-center p-4" role="dialog" aria-modal="true">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="fs-booking-backdrop"></div>
      <div class="relative w-full max-w-lg overflow-hidden rounded-3xl bg-white shadow-2xl dark:bg-slate-900" style="max-height:90vh;overflow-y:auto;">
        <!-- Progress bar -->
        <div class="h-1 bg-gray-100 dark:bg-slate-800">
          <div id="fs-progress-bar" class="h-full bg-primary transition-all duration-500" style="width:25%"></div>
        </div>
        <!-- Header -->
        <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100 dark:border-slate-800">
          <div>
            <p id="fs-modal-step-label" class="text-xs font-semibold uppercase tracking-widest text-primary mb-0.5">Step 1 of 3</p>
            <h2 id="fs-modal-title" class="text-xl font-bold text-slate-900 dark:text-white">Pick a Date</h2>
          </div>
          <button id="fs-booking-close" class="flex h-9 w-9 items-center justify-center rounded-full border border-gray-200 text-gray-400 hover:bg-gray-50 dark:border-slate-700 dark:hover:bg-slate-800 transition-colors" aria-label="Close">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
        <!-- Body -->
        <div class="px-6 py-6">
          <!-- Step 1: Date -->
          <div id="fs-step-1">
            <div id="fs-calendar-grid" class="grid grid-cols-7 gap-1.5 text-center text-sm"></div>
          </div>
          <!-- Step 2: Time -->
          <div id="fs-step-2" class="hidden">
            <p id="fs-selected-date-label" class="mb-4 text-sm font-medium text-slate-500 dark:text-slate-400"></p>
            <div id="fs-time-grid" class="grid grid-cols-3 gap-2"></div>
          </div>
          <!-- Step 3: Details -->
          <div id="fs-step-3" class="hidden space-y-3">
            <p id="fs-booking-summary" class="rounded-xl bg-gray-50 dark:bg-slate-800 px-4 py-3 text-sm text-slate-600 dark:text-slate-300"></p>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Full Name <span class="text-red-400">*</span></label>
              <input id="fs-name" type="text" placeholder="Your full name" autocomplete="name" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm text-slate-900 dark:text-white placeholder:text-gray-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors" />
              <p id="fs-err-name" class="hidden mt-1 text-xs text-red-500">Please enter your full name.</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Email Address <span class="text-red-400">*</span></label>
              <input id="fs-email" type="email" placeholder="you@example.com" autocomplete="email" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm text-slate-900 dark:text-white placeholder:text-gray-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors" />
              <p id="fs-err-email" class="hidden mt-1 text-xs text-red-500">Please enter a valid email address.</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Phone <span class="text-gray-400 font-normal">(optional)</span></label>
              <input id="fs-phone" type="tel" placeholder="+1 (555) 000-0000" autocomplete="tel" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm text-slate-900 dark:text-white placeholder:text-gray-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors" />
              <p id="fs-err-phone" class="hidden mt-1 text-xs text-red-500">Please enter a valid phone number.</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Notes <span class="text-gray-400 font-normal">(optional)</span></label>
              <textarea id="fs-notes" rows="2" placeholder="Anything you'd like us to know..." class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm text-slate-900 dark:text-white placeholder:text-gray-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors resize-none"></textarea>
            </div>
          </div>
          <!-- Step 4: Confirmed -->
          <div id="fs-step-4" class="hidden text-center py-4">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">You're Booked!</h3>
            <p id="fs-confirm-summary" class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-1"></p>
            <p class="text-slate-400 dark:text-slate-500 text-xs">A confirmation email has been sent to <span id="fs-confirm-email" class="font-semibold text-primary"></span></p>
          </div>
        </div>
        <!-- Footer -->
        <div id="fs-modal-footer" class="px-6 pb-6 flex gap-3">
          <button id="fs-btn-back" class="hidden flex-1 rounded-xl border border-gray-200 dark:border-slate-700 px-4 py-3 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors">Back</button>
          <button id="fs-btn-next" class="flex-1 btn-primary justify-center rounded-xl px-4 py-3 text-sm font-semibold transition-colors">Continue</button>
        </div>
      </div>
    </div>

    <script is:inline>
    (function() {
      var DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      var MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      var TIMES = ['9:00 AM','10:00 AM','11:00 AM','1:00 PM','2:00 PM','3:00 PM','4:00 PM','5:00 PM'];
      var UNAVAIL_DAYS = [0, 6]; // Sun, Sat
      var step = 1, selectedDate = null, selectedTime = null;

      function openModal() {
        step = 1; selectedDate = null; selectedTime = null;
        renderCalendar();
        updateModal();
        var m = document.getElementById('fs-booking-modal');
        m.classList.remove('hidden');
        m.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
      function closeModal() {
        var m = document.getElementById('fs-booking-modal');
        m.classList.add('hidden');
        m.classList.remove('flex');
        document.body.style.overflow = '';
      }

      function renderCalendar() {
        var grid = document.getElementById('fs-calendar-grid');
        if (!grid) return;
        var today = new Date(); today.setHours(0,0,0,0);
        var html = DAYS.map(function(d){ return '<div class="py-1 text-xs font-semibold text-slate-400 dark:text-slate-500">'+d+'</div>'; }).join('');
        // start from Monday of current week
        var start = new Date(today);
        start.setDate(today.getDate() - today.getDay() + 1);
        for (var i = 0; i < 21; i++) {
          var d = new Date(start); d.setDate(start.getDate() + i);
          var isPast = d < today;
          var isUnavail = UNAVAIL_DAYS.indexOf(d.getDay()) !== -1 || isPast;
          var isToday = d.toDateString() === today.toDateString();
          var key = d.toISOString().split('T')[0];
          var cls = 'cursor-pointer rounded-xl py-2 text-sm font-medium transition-all ';
          if (isUnavail) cls += 'cursor-not-allowed text-gray-300 dark:text-slate-600';
          else if (isToday) cls += 'bg-primary text-white shadow-md';
          else cls += 'hover:bg-primary/10 dark:hover:bg-primary/20 text-slate-700 dark:text-slate-300';
          html += '<button class="'+cls+'" '+(isUnavail?'disabled':'')+' data-date="'+key+'" data-label="'+DAYS[d.getDay()]+', '+MONTHS[d.getMonth()]+' '+d.getDate()+'">'+d.getDate()+'</button>';
        }
        grid.innerHTML = html;
        grid.querySelectorAll('[data-date]').forEach(function(btn){
          btn.addEventListener('click', function(){
            selectedDate = { key: this.dataset.date, label: this.dataset.label };
            step = 2; renderTimes(); updateModal();
          });
        });
      }

      function renderTimes() {
        var grid = document.getElementById('fs-time-grid');
        if (!grid) return;
        var label = document.getElementById('fs-selected-date-label');
        if (label && selectedDate) label.textContent = 'Available times for ' + selectedDate.label;
        var html = TIMES.map(function(t, i){
          var isBusy = [1,4].indexOf(i) !== -1;
          if (isBusy) return '<button disabled class="rounded-xl border border-dashed border-gray-200 dark:border-slate-700 py-3 text-sm text-gray-300 dark:text-slate-600 cursor-not-allowed">'+t+'</button>';
          return '<button class="rounded-xl border border-gray-200 dark:border-slate-700 py-3 text-sm font-medium text-slate-700 dark:text-slate-300 hover:border-primary hover:bg-primary/5 dark:hover:border-primary dark:hover:bg-primary/10 transition-all" data-time="'+t+'">'+t+'</button>';
        }).join('');
        grid.innerHTML = html;
        grid.querySelectorAll('[data-time]').forEach(function(btn){
          btn.addEventListener('click', function(){
            grid.querySelectorAll('[data-time]').forEach(function(b){
              b.classList.remove('border-primary','bg-primary/10','dark:bg-primary/20','font-bold');
            });
            this.classList.add('border-primary','bg-primary/10','font-bold');
            selectedTime = this.dataset.time;
          });
        });
      }

      function updateModal() {
        var titles = ['Pick a Date','Pick a Time','Your Details',''];
        var labels = ['Step 1 of 3','Step 2 of 3','Step 3 of 3','Confirmed!'];
        var progress = [25, 50, 75, 100];
        document.getElementById('fs-modal-title').textContent = titles[step-1];
        document.getElementById('fs-modal-step-label').textContent = labels[step-1];
        document.getElementById('fs-progress-bar').style.width = progress[step-1] + '%';
        ['fs-step-1','fs-step-2','fs-step-3','fs-step-4'].forEach(function(id, i){
          document.getElementById(id).classList.toggle('hidden', i !== step-1);
        });
        var back = document.getElementById('fs-btn-back');
        var next = document.getElementById('fs-btn-next');
        var footer = document.getElementById('fs-modal-footer');
        if (step === 4) { footer.classList.add('hidden'); return; }
        footer.classList.remove('hidden');
        back.classList.toggle('hidden', step === 1);
        var nextLabels = ['','Continue','Confirm Booking',''];
        next.textContent = nextLabels[step-1] || 'Continue';
        if (step === 3) {
          var sum = document.getElementById('fs-booking-summary');
          if (sum && selectedDate && selectedTime) sum.textContent = '📅 ' + selectedDate.label + ' at ' + selectedTime;
        }
      }

      function handleNext() {
        if (step === 1) { if (!selectedDate) return; step = 2; renderTimes(); updateModal(); }
        else if (step === 2) { if (!selectedTime) return; step = 3; updateModal(); }
        else if (step === 3) {
          var name  = document.getElementById('fs-name').value.trim();
          var email = document.getElementById('fs-email').value.trim();
          var phone = (document.getElementById('fs-phone') || {value:''}).value.trim();
          var valid = true;
          // helpers
          function setErr(id, show) {
            var el = document.getElementById(id);
            if (el) { el.classList[show ? 'remove' : 'add']('hidden'); }
          }
          function setBorder(id, err) {
            var el = document.getElementById(id);
            if (el) {
              el.style.borderColor = err ? '#ef4444' : '';
              el.style.boxShadow  = err ? '0 0 0 2px rgba(239,68,68,0.2)' : '';
            }
          }
          // clear previous errors
          ['fs-err-name','fs-err-email','fs-err-phone'].forEach(function(id){ setErr(id, false); });
          ['fs-name','fs-email','fs-phone'].forEach(function(id){ setBorder(id, false); });
          // validate name
          if (!name) { setErr('fs-err-name', true); setBorder('fs-name', true); valid = false; }
          // validate email
          var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
          if (!email || !emailOk) { setErr('fs-err-email', true); setBorder('fs-email', true); valid = false; }
          // validate phone (optional but if filled must look like a phone)
          if (phone && !/^[+\d][\d\s\-().]{6,}$/.test(phone)) { setErr('fs-err-phone', true); setBorder('fs-phone', true); valid = false; }
          if (!valid) return;
          // all good — show confirmation
          document.getElementById('fs-confirm-summary').textContent = selectedDate.label + ' at ' + selectedTime;
          document.getElementById('fs-confirm-email').textContent = email;
          step = 4; updateModal();
          setTimeout(closeModal, 4000);
        }
      }

    document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('fs-booking-close')?.addEventListener('click', closeModal);
        document.getElementById('fs-booking-backdrop')?.addEventListener('click', closeModal);
        document.getElementById('fs-btn-next')?.addEventListener('click', handleNext);
        document.getElementById('fs-btn-back')?.addEventListener('click', function(){
          if (step > 1) { step--; if (step === 1) renderCalendar(); updateModal(); }
        });

        // Intercept booking CTA buttons (skip in iframe — nav links work normally there)
        if (window.self === window.top) {
          document.querySelectorAll('a.btn-primary, a.btn-outline, button.btn-primary').forEach(function(el){
            var text = (el.textContent || '').toLowerCase();
            if (text.match(/book|schedule|session|appointment|start|begin|trial/)) {
              el.addEventListener('click', function(e){
                e.preventDefault(); openModal();
              });
            }
          });
        }

        // In preview iframe, wire explicit "Book" buttons to open modal
        if (window.self !== window.top) {
          document.querySelectorAll('[data-booking], .fs-book-btn').forEach(function(el){
            el.addEventListener('click', function(e){ e.preventDefault(); openModal(); });
          });
        }
      });
    })();
    </script>
    <!-- ═══ End Booking Modal ═══ -->

  </body>
</html>
