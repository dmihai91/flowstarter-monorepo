---
import '../styles/global.css';
import Analytics from '../components/integrations/Analytics.astro';
import ContactScript from '../../../shared/ContactScript.astro';
import { frontmatter as contactFormData } from '../../content/integrations/contact-form.md';

type Props = {
  title?: string;
  description?: string;
}

interface ContactFormContent {
  action_url?: string | null;
  success_message?: string | null;
}

const { 
  title = "Sophie Martin - Language Teacher",
  description = "Compassionate therapy services helping individuals, couples, and families navigate life's challenges. Begin your journey to healing today."
} = Astro.props;
const contactForm = contactFormData as ContactFormContent;
const contactFormActionUrl = typeof contactForm.action_url === 'string' ? contactForm.action_url : '';
const contactFormSuccessMessage =
  typeof contactForm.success_message === 'string'
    ? contactForm.success_message
    : "Thank you for reaching out! We'll be in touch within 24 hours.";

const navLinks = [
  { label: "Home", href: "#" },
  { label: "About", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Approach", href: "#approach" },
  { label: "FAQ", href: "#faq" },
  { label: "Contact", href: "#contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800&family=Nunito+Sans:wght@400;600&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --font-heading: "Nunito", serif;
        --font-body: "Nunito Sans", sans-serif;
        --color-primary: #FF6B6B;
        --color-primary-light: #ff7a7a;
        --color-primary-dark: #e66060;
        --color-secondary: #FFF8F0;
        --color-accent: #4ECDC4;
        --color-background: #FFFDF9;
        --color-surface: #FFFFFF;
        --color-text: #2D1B1B;
        --color-text-muted: #806565;
      }

      body {
        font-family: var(--font-body);
      }

      h1, h2, h3, h4, h5, h6, .font-heading {
        font-family: var(--font-heading);
      }

      .font-body {
        font-family: var(--font-body);
      }
    
      /* hide native theme toggle when rendered inside FS preview iframe */
      html.fs-preview .theme-toggle,
      html.fs-preview #theme-toggle,
      html.fs-preview #theme-toggle-mobile { display: none !important; }
    </style>
    <Analytics />
    <title>{title}</title>
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  
  <script>
    // Sync theme from ?mode= URL param (used by library preview)
    const params = new URLSearchParams(window.location.search);
    const mode = params.get('mode');
    if (mode === 'dark') {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    } else if (mode === 'light') {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    }
  </script>

  <script is:inline>
    // FlowStarter preview bridge — postMessage API
    (function() {
      if (window.self === window.top) return; // only in iframe
      // Mark document so CSS can hide native toggles
      document.documentElement.classList.add('fs-preview');



      window.addEventListener('message', function(e) {
        if (!e.data || e.data.source !== 'fs-preview') return;
        var d = e.data;
        if (d.type === 'setTheme') {
          document.documentElement.classList.toggle('dark', d.value === 'dark');
          try { localStorage.setItem('theme', d.value); } catch(_) {}
        } else if (d.type === 'setPalette') {
          // 1. Apply theme FIRST so html.dark is set before palette CSS is evaluated
          if (d.dark !== undefined) {
            document.documentElement.classList.toggle('dark', !!d.dark);
            try { localStorage.setItem('theme', d.dark ? 'dark' : 'light'); } catch(_) {}
          }
          // 2. Set CSS vars directly on root (inline style = highest priority)
          if (d.vars) {
            var root = document.documentElement;
            var vars = d.vars;
            Object.keys(vars).forEach(function(k) { root.style.setProperty(k, vars[k]); });
            if (vars['--color-background']) document.body.style.setProperty('background-color', vars['--color-background'], 'important');
            if (vars['--color-text']) document.body.style.setProperty('color', vars['--color-text'], 'important');
          }
          // 3. Inject style tag for Tailwind utility class overrides
          var existing = document.getElementById('fs-palette-override');
          if (existing) existing.remove();
          if (d.css) {
            var style = document.createElement('style');
            style.id = 'fs-palette-override';
            style.textContent = d.css;
            document.head.appendChild(style);
          }
        } else if (d.type === 'setFont') {
          // swap Google Fonts link
          var existing = document.getElementById('fs-font-override');
          if (existing) existing.remove();
          if (d.url) {
            var link = document.createElement('link');
            link.id = 'fs-font-override';
            link.rel = 'stylesheet';
            link.href = d.url;
            document.head.appendChild(link);
          }
          // apply CSS variables
          if (d.heading) document.documentElement.style.setProperty('--font-heading', d.heading);
          if (d.body)    document.documentElement.style.setProperty('--font-body',    d.body);
        }
      });
    })();
  </script>
</head>
  <body class="min-h-screen">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-cream/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-warm-200 dark:border-slate-800 transition-colors">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
          <!-- Logo -->
          <a href="#" class="flex items-center gap-3">
            <div class="w-10 h-10 bg-primary/10 dark:bg-primary/20 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-primary"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8c0 5.5-4.78 10-10 10"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></g></svg>
            </div>
            <div>
              <span class="text-lg font-serif font-semibold text-slate-800 dark:text-white">Sophie Martin</span>
              <span class="hidden sm:inline text-sm text-slate-500 dark:text-slate-400 ml-2">TEFL</span>
            </div>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden lg:flex items-center gap-8">
            {navLinks.map((link) => (
              <a href={link.href} class="text-slate-600 dark:text-slate-300 hover:text-primary transition-colors text-sm">
                {link.label}
              </a>
            ))}
          </div>

          <!-- CTA Button -->
          <div class="hidden md:flex items-center gap-4">
            <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
