---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8" style="background: radial-gradient(circle at top, color-mix(in srgb, var(--color-primary) 24%, transparent) 0%, transparent 28%), linear-gradient(180deg, var(--color-background) 0%, color-mix(in srgb, var(--color-secondary) 86%, black) 100%);">
  <div class="absolute inset-0 opacity-40" aria-hidden="true">
    <svg class="h-full w-full" viewBox="0 0 1440 720">
      <path d="M0 480c140-80 230-80 370 0s230 80 370 0 230-80 370 0 230 80 330 20" fill="none" stroke="rgba(240,230,255,0.12)" stroke-width="2"></path>
      <path d="M0 550c160-60 260-60 400 0s260 60 400 0 260-60 400 0" fill="none" stroke="rgba(255,159,67,0.12)" stroke-width="2"></path>
      <circle cx="1120" cy="180" r="6" fill="rgba(255,159,67,0.28)"></circle>
      <circle cx="1180" cy="240" r="10" fill="rgba(107,53,168,0.32)"></circle>
    </svg>
  </div>
  <div class="relative mx-auto max-w-5xl">
    {badge && (
      <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-white/12 bg-white/8 px-5 py-2 text-sm font-medium text-white/78 backdrop-blur-xl">
        <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
        <span>{badge}</span>
      </div>
    )}
    <h1 class="max-w-4xl text-5xl leading-[1.02] text-[var(--color-surface)] sm:text-6xl lg:text-7xl" style="font-style: italic;">
      {headline}
    </h1>
    <div class="mt-5 h-1.5 w-40 rounded-full" style="background: linear-gradient(90deg, var(--color-accent), transparent);"></div>
    {subheadline && (
      <p class="mt-8 max-w-3xl text-lg leading-8 text-white/72">{subheadline}</p>
    )}
    <div class="mt-10 flex flex-col gap-4 sm:flex-row">
      {cta_primary && (
        <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-[var(--color-background)]" style="background: var(--color-accent);">{cta_primary.text}</a>
      )}
      {cta_secondary && (
        <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border border-white/18 px-7 py-4 text-sm font-semibold text-white">{cta_secondary.text}</a>
      )}
    </div>
    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {stats.map((stat: HeroStat) => (
        <div class="rounded-2xl border border-white/10 bg-white/5 px-5 py-5 text-left backdrop-blur-xl">
          <div class="text-3xl font-bold text-white">{stat.value}</div>
          <div class="mt-1 text-sm text-white/52">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
