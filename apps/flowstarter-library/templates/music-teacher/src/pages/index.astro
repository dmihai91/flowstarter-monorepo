---
import Layout from '../layouts/Layout.astro';
import { frontmatter as heroData } from '../../content/hero.md';
import { frontmatter as aboutData } from '../../content/about.md';
import { frontmatter as servicesData } from '../../content/services.md';
import { frontmatter as testimonialsData } from '../../content/testimonials.md';
import { frontmatter as siteData } from '../../content/site.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

interface Credential {
  title: string;
  institution: string;
}

interface ValueItem {
  title: string;
  description: string;
}

interface AboutContent {
  headline: string;
  intro: string;
  image?: string;
  credentials?: Credential[];
  story?: string;
  values?: ValueItem[];
}

interface ServiceItem {
  icon: string;
  title: string;
  description: string;
  price?: string;
}

interface ServicesContent {
  title: string;
  subtitle?: string;
  services: ServiceItem[];
}

interface TestimonialItem {
  quote: string;
  author: string;
  role?: string;
  result?: string;
}

interface TestimonialsContent {
  title: string;
  subtitle?: string;
  testimonials: TestimonialItem[];
}

interface SiteContent {
  name: string;
  tagline?: string;
  email: string;
  phone: string;
  location?: string;
}

interface FAQItem {
  question: string;
  answer: string;
}

const hero = heroData as HeroContent;
const about = aboutData as AboutContent;
const services = servicesData as ServicesContent;
const testimonials = testimonialsData as TestimonialsContent;
const site = siteData as SiteContent;

const storyParagraphs: string[] = (about.story ?? '').split('\n\n').filter(Boolean);
const faqItems: FAQItem[] = [
  {
    question: `How do I get started with ${site.name}?`,
    answer: `Use the contact form below and share what you want help with. We'll follow up with the best next step and answer any questions before you commit.`,
  },
  {
    question: 'Are sessions available online?',
    answer: `Yes. ${site.name} supports online appointments, and availability can vary depending on your program or location.`,
  },
  {
    question: 'Can support be tailored to specific goals?',
    answer: `Absolutely. Every engagement is shaped around your level, priorities, and timeline so the work stays practical and relevant.`,
  },
  {
    question: 'How is pricing handled?',
    answer: 'Pricing depends on the service or format you choose. Reach out with what you need and we will recommend the best-fit option.',
  },
];
---

<Layout>
  <section class="relative overflow-hidden pt-28 pb-20 md:pt-36 md:pb-24">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/10"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          {hero.badge && (
            <p class="inline-flex items-center rounded-full bg-primary/10 px-4 py-2 text-sm font-medium text-primary mb-6">
              {hero.badge}
            </p>
          )}
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold text-slate-900 dark:text-white leading-tight">
            {hero.headline}
          </h1>
          <p class="mt-6 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
            {hero.subheadline}
          </p>
          {site.tagline && (
            <p class="mt-4 text-sm uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">
              {site.tagline}
            </p>
          )}
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            {hero.cta_primary && (
              <a href={hero.cta_primary.href} class="btn-primary">
                {hero.cta_primary.text}
              </a>
            )}
            {hero.cta_secondary && (
              <a href={hero.cta_secondary.href} class="btn-outline">
                {hero.cta_secondary.text}
              </a>
            )}
          </div>
          <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-3">
            {(hero.stats ?? []).map((stat: HeroStat) => (
              <div class="rounded-2xl bg-white/90 dark:bg-slate-800/80 p-5 shadow-sm ring-1 ring-slate-200/70 dark:ring-slate-700/70">
                <div class="text-2xl font-serif font-semibold text-slate-900 dark:text-white">{stat.value}</div>
                <div class="mt-1 text-sm text-slate-500 dark:text-slate-400">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 translate-x-4 translate-y-4 rounded-[2rem] bg-primary/15 blur-2xl"></div>
          <div class="relative overflow-hidden rounded-[2rem] bg-white dark:bg-slate-800 shadow-2xl ring-1 ring-slate-200 dark:ring-slate-700">
            {about.image ? (
              <img src={about.image} alt={about.headline} class="h-full w-full object-cover aspect-[4/5]" />
            ) : (
              <div class="aspect-[4/5] bg-gradient-to-br from-primary/20 to-secondary/20"></div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="py-20 bg-slate-50/80 dark:bg-slate-800/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr]">
        <div>
          <p class="text-primary font-medium mb-4">About</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-900 dark:text-white">
            {about.headline}
          </h2>
          <p class="mt-6 text-lg text-slate-600 dark:text-slate-300">
            {about.intro}
          </p>
          <div class="mt-8 space-y-4">
            {storyParagraphs.map((paragraph: string) => (
              <p class="text-slate-600 dark:text-slate-300">{paragraph}</p>
            ))}
          </div>
        </div>

        <div class="space-y-8">
          <div class="rounded-3xl bg-white dark:bg-slate-900 p-8 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700">
            <h3 class="text-xl font-serif font-semibold text-slate-900 dark:text-white mb-6">Credentials</h3>
            <div class="space-y-4">
              {(about.credentials ?? []).map((credential: Credential) => (
                <div class="flex items-start gap-4">
                  <div class="mt-1 h-3 w-3 rounded-full bg-primary"></div>
                  <div>
                    <div class="font-medium text-slate-900 dark:text-white">{credential.title}</div>
                    <div class="text-sm text-slate-500 dark:text-slate-400">{credential.institution}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-3">
            {(about.values ?? []).map((value: ValueItem) => (
              <div class="rounded-3xl bg-white dark:bg-slate-900 p-6 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700">
                <h3 class="text-lg font-serif font-semibold text-slate-900 dark:text-white">{value.title}</h3>
                <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">{value.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="services" class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-primary font-medium mb-4">Services</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-900 dark:text-white">
          {services.title}
        </h2>
        {services.subtitle && (
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">{services.subtitle}</p>
        )}
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {services.services.map((service: ServiceItem) => (
          <div class="rounded-3xl bg-white dark:bg-slate-900 p-8 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-lg font-semibold text-primary">
              {service.title.charAt(0)}
            </div>
            <h3 class="mt-6 text-xl font-serif font-semibold text-slate-900 dark:text-white">{service.title}</h3>
            <p class="mt-3 text-slate-600 dark:text-slate-300">{service.description}</p>
            {service.price && (
              <p class="mt-4 text-sm font-medium text-primary">{service.price}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="testimonials" class="py-20 bg-slate-50/80 dark:bg-slate-800/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-primary font-medium mb-4">Testimonials</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-900 dark:text-white">
          {testimonials.title}
        </h2>
        {testimonials.subtitle && (
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">{testimonials.subtitle}</p>
        )}
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {testimonials.testimonials.map((testimonial: TestimonialItem) => (
          <div class="rounded-3xl bg-white dark:bg-slate-900 p-8 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700">
            <p class="text-lg leading-8 text-slate-700 dark:text-slate-200">"{testimonial.quote}"</p>
            {testimonial.result && (
              <p class="mt-5 inline-flex rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">
                {testimonial.result}
              </p>
            )}
            <div class="mt-6 border-t border-slate-200 dark:border-slate-700 pt-4">
              <div class="font-semibold text-slate-900 dark:text-white">{testimonial.author}</div>
              {testimonial.role && (
                <div class="text-sm text-slate-500 dark:text-slate-400">{testimonial.role}</div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-primary font-medium mb-4">FAQ</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-900 dark:text-white">Common Questions</h2>
      </div>

      <div class="mt-12 space-y-4">
        {faqItems.map((faq: FAQItem, index: number) => (
          <div class="faq-item overflow-hidden rounded-2xl bg-white dark:bg-slate-900 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700">
            <button class="faq-trigger flex w-full items-center justify-between px-6 py-5 text-left" data-index={index}>
              <span class="pr-4 font-medium text-slate-900 dark:text-white">{faq.question}</span>
              <span class="faq-icon text-primary">+</span>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 dark:text-slate-300">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="contact" class="py-20 bg-slate-50/80 dark:bg-slate-800/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-primary font-medium mb-4">Contact</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-900 dark:text-white">
            Start with a quick message
          </h2>
          <p class="mt-6 text-lg text-slate-600 dark:text-slate-300">
            Tell us what you are looking for and we will point you to the right service, schedule, or next step.
          </p>

          <div class="mt-8 space-y-5">
            <div>
              <div class="text-sm uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">Business</div>
              <div class="mt-1 text-lg font-medium text-slate-900 dark:text-white">{site.name}</div>
            </div>
            {site.location && (
              <div>
                <div class="text-sm uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">Location</div>
                <div class="mt-1 text-slate-700 dark:text-slate-300">{site.location}</div>
              </div>
            )}
            <div>
              <div class="text-sm uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">Email</div>
              <a href={`mailto:${site.email}`} class="mt-1 inline-block text-slate-700 dark:text-slate-300 hover:text-primary">
                {site.email}
              </a>
            </div>
            <div>
              <div class="text-sm uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">Phone</div>
              <a href={`tel:${site.phone.replace(/[^+\d]/g, '')}`} class="mt-1 inline-block text-slate-700 dark:text-slate-300 hover:text-primary">
                {site.phone}
              </a>
            </div>
          </div>
        </div>

        <div class="rounded-[2rem] bg-white dark:bg-slate-900 p-8 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700">
          <h3 class="text-2xl font-serif font-semibold text-slate-900 dark:text-white">Send an inquiry</h3>
          <form class="mt-8 space-y-5">
            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">First Name</label>
                <input type="text" class="input" placeholder="Your first name" />
              </div>
              <div>
                <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Last Name</label>
                <input type="text" class="input" placeholder="Your last name" />
              </div>
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
              <input type="email" class="input" placeholder="you@example.com" />
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Phone</label>
              <input type="tel" class="input" placeholder={site.phone} />
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">What are you looking for?</label>
              <textarea rows="5" class="textarea" placeholder={`Tell ${site.name} a bit about your goals, timeline, or questions.`}></textarea>
            </div>
            <button type="submit" class="btn-primary w-full">Submit Inquiry</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = trigger.querySelector('.faq-icon');

      document.querySelectorAll('.faq-item').forEach((otherItem) => {
        if (otherItem !== item) {
          otherItem.querySelector('.faq-content')?.classList.add('hidden');

          const otherIcon = otherItem.querySelector('.faq-icon');
          if (otherIcon) {
            otherIcon.textContent = '+';
          }
        }
      });

      content?.classList.toggle('hidden');

      if (icon) {
        icon.textContent = content?.classList.contains('hidden') ? '+' : '−';
      }
    });
  });
</script>
