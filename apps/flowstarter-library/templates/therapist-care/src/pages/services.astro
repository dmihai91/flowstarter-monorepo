---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Services from '../components/Services.astro';
---

<Layout title="Services | Therapist Care">
  <!-- Hero -->
  <section class="pt-32 pb-12 bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
          Our Services
        </h1>
        <p class="text-xl text-gray-400">
          Comprehensive solutions tailored to your needs.
        </p>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- CTA -->
  <section class="py-24 bg-gray-950">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
        Ready to Get Started?
      </h2>
      <p class="text-xl text-gray-400 mb-10">Contact us today for a free consultation.</p>
      <a href="/contact" class="btn-gradient inline-flex items-center">
        Contact Us
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>