{
  "name": "Wellness Holistic",
  "slug": "wellness-holistic",
  "description": "Template for wellness practitioners, naturopathic doctors, nutritionists, massage therapists, and holistic health providers. Calming teal and lavender design with consultation booking and wellness programs.",
  "category": "wellness",
  "tags": [
    "wellness",
    "holistic",
    "naturopathic",
    "nutrition",
    "massage",
    "acupuncture",
    "herbal-medicine",
    "mindfulness"
  ],
  "framework": "astro",
  "features": [
    "Single-page",
    "Consultation booking",
    "Wellness programs",
    "Testimonials",
    "FAQ accordion",
    "Dark mode"
  ],
  "integrations": {
    "booking": {
      "name": "Booking System",
      "description": "Connect Calendly to let clients book wellness consultations",
      "providers": [
        {
          "id": "calendly",
          "name": "Calendly",
          "field": "calendly_url",
          "placeholder": "https://calendly.com/your-username/consultation"
        },
        {
          "id": "calcom",
          "name": "Cal.com",
          "field": "calcom_url",
          "placeholder": "https://cal.com/your-username/consultation"
        }
      ],
      "optional": true,
      "configPath": "content/integrations/booking.md"
    },
    "newsletter": {
      "name": "Newsletter",
      "description": "Connect Mailchimp to collect wellness newsletter subscribers",
      "providers": [
        {
          "id": "mailchimp",
          "name": "Mailchimp",
          "field": "mailchimp_url",
          "placeholder": "https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx"
        },
        {
          "id": "convertkit",
          "name": "ConvertKit",
          "field": "convertkit_form_id",
          "placeholder": "1234567"
        },
        {
          "id": "buttondown",
          "name": "Buttondown",
          "field": "buttondown_username",
          "placeholder": "your-username"
        }
      ],
      "optional": true,
      "configPath": "content/integrations/newsletter.md"
    }
  },
  "fonts": [
    {
      "id": "font-1",
      "name": "Natural",
      "heading": "Gilda Display",
      "body": "Mulish",
      "googleFonts": "Gilda+Display:wght@400&family=Mulish:wght@300;400;600"
    },
    {
      "id": "font-2",
      "name": "Classic",
      "heading": "Cormorant Garamond",
      "body": "Inter",
      "googleFonts": "Cormorant+Garamond:wght@400;600&family=Inter:wght@400;500"
    },
    {
      "id": "font-3",
      "name": "Soft",
      "heading": "Fraunces",
      "body": "Outfit",
      "googleFonts": "Fraunces:ital,wght@0,300;1,700&family=Outfit:wght@400;500"
    },
    {
      "id": "font-4",
      "name": "Modern",
      "heading": "Manrope",
      "body": "DM Sans",
      "googleFonts": "Manrope:wght@600;800&family=DM+Sans:wght@400;500"
    }
  ]
}
