{
  "name": "Wellness Holistic",
  "slug": "wellness-holistic",
  "description": "Template for wellness practitioners, naturopathic doctors, nutritionists, massage therapists, and holistic health providers. Calming teal and lavender design with consultation booking and wellness programs.",
  "category": "wellness",
  "tags": [
    "wellness",
    "holistic",
    "naturopathic",
    "nutrition",
    "massage",
    "acupuncture",
    "herbal-medicine",
    "mindfulness"
  ],
  "framework": "astro",
  "features": [
    "Single-page",
    "Consultation booking",
    "Wellness programs",
    "Testimonials",
    "FAQ accordion",
    "Dark mode"
  ],
  "integrations": {
    "booking": {
      "name": "Booking System",
      "description": "Connect Calendly to let clients book wellness consultations",
      "providers": [
        {
          "id": "calendly",
          "name": "Calendly",
          "field": "calendly_url",
          "placeholder": "https://calendly.com/your-username/consultation"
        },
        {
          "id": "calcom",
          "name": "Cal.com",
          "field": "calcom_url",
          "placeholder": "https://cal.com/your-username/consultation"
        }
      ],
      "optional": true,
      "configPath": "content/integrations/booking.md"
    },
    "newsletter": {
      "name": "Newsletter",
      "description": "Connect Mailchimp to collect wellness newsletter subscribers",
      "providers": [
        {
          "id": "mailchimp",
          "name": "Mailchimp",
          "field": "mailchimp_url",
          "placeholder": "https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx"
        },
        {
          "id": "convertkit",
          "name": "ConvertKit",
          "field": "convertkit_form_id",
          "placeholder": "1234567"
        },
        {
          "id": "buttondown",
          "name": "Buttondown",
          "field": "buttondown_username",
          "placeholder": "your-username"
        }
      ],
      "optional": true,
      "configPath": "content/integrations/newsletter.md"
    }
  }
}