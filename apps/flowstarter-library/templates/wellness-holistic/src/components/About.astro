---
import { frontmatter as aboutFrontmatter } from '../../content/about.md';
import Icon from './Icon.astro';

interface HighlightItem {
  title: string;
  description: string;
}

interface AboutData {
  eyebrow: string;
  title: string;
  intro: string;
  story: string;
  image: string;
  image_alt: string;
  credentials: string[];
  highlights: HighlightItem[];
}

const about = aboutFrontmatter as AboutData;
const credentials: string[] = about.credentials;
const highlights: HighlightItem[] = about.highlights;
---

<section id="about" class="section-shell">
  <div class="grid items-center gap-8 lg:grid-cols-[0.92fr_1.08fr]">
    <div class="glass-card overflow-hidden p-3">
      <img src={about.image} alt={about.image_alt} class="h-full min-h-[420px] w-full rounded-[1.1rem] object-cover" loading="lazy" />
    </div>

    <div>
      <span class="section-kicker">{about.eyebrow}</span>
      <h2 class="section-title mt-4">{about.title}</h2>
      <p class="mt-5 text-base leading-8 text-[var(--color-text-muted)]">{about.intro}</p>
      <p class="mt-4 text-base leading-8 text-[var(--color-text-muted)]">{about.story}</p>

      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        {credentials.map((credential: string) => (
          <div class="glass-card p-4 text-sm text-[var(--color-text)]">
            <span class="flex items-start gap-3">
              <Icon name="check-circle" class="mt-0.5 h-4 w-4 text-[var(--color-primary)]" />
              <span>{credential}</span>
            </span>
          </div>
        ))}
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {highlights.map((item: HighlightItem) => (
          <article class="glass-card p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--color-primary)]">{item.title}</p>
            <p class="mt-3 text-sm leading-7 text-[var(--color-text-muted)]">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
