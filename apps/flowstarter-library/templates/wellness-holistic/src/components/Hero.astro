---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8">
  <div class="absolute inset-0 bg-[linear-gradient(180deg,#fdfaf6_0%,#f7f3ee_100%)]"></div>
  <div class="absolute left-1/2 top-16 h-[34rem] w-[34rem] -translate-x-1/2 rounded-full blur-3xl" style="background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 22%, white) 0%, color-mix(in srgb, var(--color-accent) 18%, transparent) 46%, transparent 72%);"></div>
  <div class="relative mx-auto max-w-5xl text-center">
    {badge && (
      <div class="mx-auto mb-8 inline-flex items-center gap-3 rounded-full border px-5 py-2 text-sm font-medium backdrop-blur-xl" style="border-color: color-mix(in srgb, var(--color-primary) 18%, white); background: color-mix(in srgb, var(--color-surface) 72%, transparent); color: var(--color-text);">
        <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
        <span>{badge}</span>
      </div>
    )}
    <div class="mx-auto mb-6 flex h-72 w-72 items-center justify-center rounded-full border border-white/55 bg-white/40 backdrop-blur-md sm:h-80 sm:w-80">
      <div class="h-56 w-56 rounded-full" style="background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.92), color-mix(in srgb, var(--color-primary) 34%, white) 42%, color-mix(in srgb, var(--color-accent) 18%, transparent) 74%);"></div>
    </div>
    <h1 class="mx-auto max-w-4xl text-5xl leading-[1] text-[var(--color-text)] sm:text-6xl lg:text-7xl">{headline}</h1>
    {subheadline && (
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-[color:var(--color-text-muted)]">{subheadline}</p>
    )}
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      {cta_primary && (
        <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-white shadow-lg shadow-black/10" style="background: var(--color-primary);">{cta_primary.text}</a>
      )}
      {cta_secondary && (
        <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border px-7 py-4 text-sm font-semibold" style="border-color: color-mix(in srgb, var(--color-accent) 32%, white); color: var(--color-text); background: color-mix(in srgb, var(--color-surface) 76%, transparent);">{cta_secondary.text}</a>
      )}
    </div>
    <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
      {stats.map((stat: HeroStat) => (
        <div class="rounded-2xl border border-white/72 bg-white/72 px-5 py-5 text-left shadow-lg shadow-black/5 backdrop-blur-xl">
          <div class="text-3xl text-[var(--color-text)]">{stat.value}</div>
          <div class="mt-1 text-sm text-[color:var(--color-text-muted)]">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
