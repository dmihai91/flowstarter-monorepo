---
import { frontmatter as testimonialsFrontmatter } from '../../content/testimonials.md';
import Icon from './Icon.astro';

interface TestimonialItem {
  quote: string;
  author: string;
  role: string;
  result: string;
}

interface TestimonialsData {
  title: string;
  subtitle: string;
  testimonials: TestimonialItem[];
}

const data = testimonialsFrontmatter as TestimonialsData;
const testimonials: TestimonialItem[] = data.testimonials;
---

<section id="testimonials" class="section-shell">
  <div class="section-heading">
    <span class="section-kicker">Testimonials</span>
    <h2 class="section-title">{data.title}</h2>
    <p class="section-copy">{data.subtitle}</p>
  </div>

  <div class="mt-12 grid gap-6 lg:grid-cols-3">
    {testimonials.map((item: TestimonialItem) => (
      <article class="glass-card p-6">
        <div class="flex items-center justify-between gap-4">
          <Icon name="quote" class="h-8 w-8 text-[var(--color-primary)]" />
          <span class="rounded-full bg-white/20 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.24em] text-[var(--color-text)]">
            {item.result}
          </span>
        </div>
        <p class="mt-6 text-base leading-8 text-[var(--color-text)]">"{item.quote}"</p>
        <div class="mt-8 border-t border-white/15 pt-4">
          <p class="text-sm font-semibold text-[var(--color-text)]">{item.author}</p>
          <p class="mt-1 text-xs uppercase tracking-[0.22em] text-[var(--color-text-muted)]">{item.role}</p>
        </div>
      </article>
    ))}
  </div>
</section>
