---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

interface Service {
  icon: string;
  title: string;
  description: string;
  price: string;
}

interface PhilosophyItem {
  title: string;
  description: string;
}

interface Testimonial {
  quote: string;
  author: string;
  type: string;
}

interface FAQ {
  question: string;
  answer: string;
}

interface Credential {
  text: string;
}

const services: Service[] = [
  { icon: "lucide:apple", title: "Nutritional Counseling", description: "Custom meal plans and dietary strategies based on your unique biochemistry, food sensitivities, and health goals.", price: "$175/session" },
  { icon: "lucide:hand", title: "Massage Therapy", description: "Therapeutic deep tissue and Swedish massage to release tension, improve circulation, and promote deep relaxation.", price: "$120/session" },
  { icon: "lucide:target", title: "Acupuncture", description: "Traditional Chinese medicine techniques to restore energy flow, reduce pain, and support whole-body healing.", price: "$150/session" },
  { icon: "lucide:flower-2", title: "Herbal Medicine", description: "Custom herbal formulations using evidence-based botanicals to support your body's natural healing processes.", price: "$125/consultation" },
  { icon: "lucide:brain", title: "Stress & Mindfulness", description: "Guided meditation, breathwork, and stress-reduction techniques for lasting calm and mental clarity.", price: "$100/session" },
  { icon: "lucide:sparkles", title: "Wellness Programs", description: "Comprehensive 8-week Holistic Reset program combining nutrition, movement, mindfulness, and accountability.", price: "$899/program" },
];

const philosophy: PhilosophyItem[] = [
  { title: "Root Cause Approach", description: "Rather than masking symptoms, we identify and address the underlying imbalances causing your health concerns." },
  { title: "Mind-Body Connection", description: "True healing integrates mental, emotional, and physical health. We treat you as a whole person, not a collection of symptoms." },
  { title: "Nature's Wisdom", description: "We harness the healing power of nature through herbal medicine, nutrition, and natural therapies proven over centuries." },
  { title: "Personalized Protocols", description: "No two bodies are the same. Every treatment plan is customized to your unique biochemistry, lifestyle, and goals." },
];

const testimonials: Testimonial[] = [
  { quote: "After years of digestive issues that no conventional doctor could solve, Dr. Rodriguez identified the root cause in our first visit. Six months later, my gut health is completely transformed.", author: "Amanda K.", type: "Gut Health Patient" },
  { quote: "The combination of acupuncture and herbal medicine finally gave me relief from chronic back pain I'd been living with for a decade. Elena's integrative approach is truly remarkable.", author: "Robert S.", type: "Chronic Pain Patient" },
  { quote: "I came in exhausted and burned out. Through the wellness program, I discovered the nutritional deficiencies draining my energy. I now wake up feeling vibrant every day.", author: "Jennifer L.", type: "Wellness Program Graduate" },
];

const faqs: FAQ[] = [
  { question: "What should I expect at my first visit?", answer: "Your initial consultation is a comprehensive 90-minute session where we review your health history, current concerns, lifestyle, and goals. I may recommend lab work to identify underlying imbalances. Together, we'll create a personalized treatment plan." },
  { question: "Do you accept insurance?", answer: "I am an out-of-network provider for most insurance plans. I provide detailed superbills that you can submit for potential reimbursement. Many HSA and FSA accounts can also be used for naturopathic services." },
  { question: "How long until I see results?", answer: "This varies by condition and individual. Some patients notice improvements within 2-4 weeks, while chronic conditions may take 3-6 months of consistent treatment. We'll set realistic expectations and track progress together." },
  { question: "Do you prescribe supplements?", answer: "When appropriate, I recommend professional-grade supplements and herbal formulations. I only suggest what's necessary based on your lab results and clinical assessment — never a one-size-fits-all approach." },
  { question: "Do you offer virtual consultations?", answer: "Yes! I offer secure video consultations for follow-up visits and nutritional counseling sessions. Initial visits are recommended in-person for the most thorough assessment." },
];

const credentials: string[] = [
  "Naturopathic Doctor (ND), Bastyr University",
  "Licensed Naturopathic Physician, Oregon",
  "Certified Clinical Nutritionist (CCN)",
  "12+ Years Clinical Experience",
];

const stats = [
  { value: "1,200+", label: "Patients Helped" },
  { value: "12", label: "Years Experience" },
  { value: "95%", label: "Satisfaction Rate" },
  { value: "4.9", label: "Average Rating" },
];
---

<Layout>
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-sage-100 dark:from-slate-800/50 to-transparent opacity-50"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>
    
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-primary font-medium mb-4 flex items-center gap-2">
            <Icon name="lucide:award" class="w-5 h-5" />
            Licensed Naturopathic Doctor
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold text-slate-800 dark:text-white leading-tight mb-6">
            Restore Balance. Reclaim <span class="text-primary">Vitality</span>.
          </h1>
          <p class="text-lg text-slate-600 dark:text-slate-400 mb-8 max-w-lg">
            I'm Dr. Elena Rodriguez, and I combine ancient healing wisdom with modern science to address the root cause of your health concerns. Together, we'll create a personalized path to lasting wellness.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="#contact" class="btn-primary">
              Book a Consultation
              <Icon name="lucide:arrow-right" class="w-5 h-5 ml-2" />
            </a>
            <a href="#services" class="btn-outline">Explore Services</a>
          </div>
          <div class="grid grid-cols-4 gap-4">
            {stats.map((stat: { value: string; label: string }) => (
              <div class="text-center">
                <div class="text-2xl font-serif font-bold text-slate-800 dark:text-white">{stat.value}</div>
                <div class="text-xs text-slate-500 dark:text-slate-400">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
        
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-3xl transform rotate-3"></div>
          <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=600&h=700&fit=crop&crop=face" alt="Dr. Elena Rodriguez, ND" class="relative rounded-3xl shadow-xl w-full object-cover aspect-[5/6]" />
          <div class="absolute -bottom-6 -left-6 bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                <Icon name="lucide:flower-2" class="w-6 h-6 text-primary" />
              </div>
              <div>
                <div class="text-2xl font-serif font-bold text-slate-800 dark:text-white">12+</div>
                <div class="text-sm text-slate-500 dark:text-slate-400">Years Healing</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 bg-sage-50 dark:bg-slate-800/50 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <div class="grid grid-cols-2 gap-4">
            <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=300&h=400&fit=crop" alt="Wellness consultation" class="rounded-2xl shadow-md w-full object-cover aspect-[3/4]" />
            <img src="https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?w=300&h=400&fit=crop" alt="Herbal medicine" class="rounded-2xl shadow-md w-full object-cover aspect-[3/4] mt-8" />
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <p class="text-primary font-medium mb-4">About Me</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">
            Healing the Whole Person
          </h2>
          <p class="text-slate-600 dark:text-slate-400 mb-6">
            With a doctorate in Naturopathic Medicine from Bastyr University, I've spent over 12 years helping patients restore balance through integrative, root-cause medicine.
          </p>
          <p class="text-slate-600 dark:text-slate-400 mb-8">
            I specialize in gut health, hormonal balance, stress management, and autoimmune conditions. My approach combines nutritional science, herbal medicine, acupuncture, and lifestyle optimization to support your body's innate healing ability.
          </p>
          <ul class="space-y-3">
            {credentials.map((credential: string) => (
              <li class="flex items-center gap-3">
                <Icon name="lucide:check-circle" class="w-5 h-5 text-primary flex-shrink-0" />
                <span class="text-slate-700 dark:text-slate-300">{credential}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-20 bg-cream dark:bg-slate-900 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-primary font-medium mb-4">Services</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Holistic Wellness Services</h2>
        <p class="text-slate-600 dark:text-slate-400">Comprehensive natural healthcare tailored to your unique needs. Each service supports your body's innate ability to heal.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service: Service) => (
          <div class="card group hover:-translate-y-1">
            <div class="w-14 h-14 bg-primary/10 dark:bg-primary/20 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-primary/20 dark:group-hover:bg-primary/30 transition-colors">
              <Icon name={service.icon} class="w-7 h-7 text-primary" />
            </div>
            <h3 class="text-xl font-serif font-semibold text-slate-800 dark:text-white mb-2">{service.title}</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-4">{service.description}</p>
            <span class="inline-flex items-center gap-2 text-sm text-primary font-medium">
              {service.price}
            </span>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="#contact" class="btn-primary">
          Book Your Consultation
          <Icon name="lucide:calendar" class="w-5 h-5 ml-2" />
        </a>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section id="philosophy" class="py-20 bg-warm-100 dark:bg-slate-800/50 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-primary font-medium mb-4">Philosophy</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">My Healing Philosophy</h2>
        <p class="text-slate-600 dark:text-slate-400">A holistic approach that honors your body's wisdom and supports lasting transformation from the inside out.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {philosophy.map((item: PhilosophyItem, index: number) => (
          <div class="flex gap-5">
            <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-serif font-bold flex-shrink-0">{index + 1}</div>
            <div>
              <h3 class="text-xl font-serif font-semibold text-slate-800 dark:text-white mb-2">{item.title}</h3>
              <p class="text-slate-600 dark:text-slate-400">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 bg-cream dark:bg-slate-900 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-primary font-medium mb-4">Testimonials</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Patient Stories</h2>
        <p class="text-slate-600 dark:text-slate-400">Hear from those who have experienced the transformative power of holistic wellness.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((testimonial: Testimonial) => (
          <div class="card-warm">
            <div class="mb-4"><Icon name="lucide:quote" class="w-10 h-10 text-primary/30" /></div>
            <p class="text-slate-700 dark:text-slate-300 mb-6 leading-relaxed italic">"{testimonial.quote}"</p>
            <div class="border-t border-warm-300 dark:border-slate-700 pt-4">
              <div class="font-semibold text-slate-800 dark:text-white">{testimonial.author}</div>
              <div class="text-sm text-slate-500 dark:text-slate-400">{testimonial.type}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-20 bg-sage-50 dark:bg-slate-800/50 transition-colors">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-primary font-medium mb-4">FAQ</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Common Questions</h2>
        <p class="text-slate-600 dark:text-slate-400">Find answers to frequently asked questions about holistic wellness care.</p>
      </div>

      <div class="space-y-4">
        {faqs.map((faq: FAQ, index: number) => (
          <div class="faq-item bg-white dark:bg-slate-800 rounded-xl shadow-sm dark:shadow-none dark:border dark:border-slate-700 overflow-hidden">
            <button class="faq-trigger w-full px-6 py-5 flex items-center justify-between text-left" data-index={index}>
              <span class="font-medium text-slate-800 dark:text-white pr-4">{faq.question}</span>
              <Icon name="lucide:chevron-down" class="w-5 h-5 text-primary transition-transform faq-icon flex-shrink-0" />
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 dark:text-slate-400">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 bg-cream dark:bg-slate-900 transition-colors">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <p class="text-primary font-medium mb-4">Get Started</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Begin Your Wellness Journey</h2>
          <p class="text-slate-600 dark:text-slate-400 mb-8">Ready to take the first step toward vibrant health? Schedule a consultation and let's create your personalized wellness plan together.</p>

          <div class="space-y-6 mb-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 dark:bg-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:map-pin" class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h4 class="font-semibold text-slate-800 dark:text-white mb-1">Clinic Location</h4>
                <p class="text-slate-600 dark:text-slate-400">2847 NW Healing Way<br>Portland, OR 97210</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 dark:bg-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:clock" class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h4 class="font-semibold text-slate-800 dark:text-white mb-1">Clinic Hours</h4>
                <p class="text-slate-600 dark:text-slate-400">Monday – Thursday: 9am – 6pm<br>Friday: 9am – 2pm</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 dark:bg-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:phone" class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h4 class="font-semibold text-slate-800 dark:text-white mb-1">Contact</h4>
                <p class="text-slate-600 dark:text-slate-400">
                  <a href="tel:+15035550142" class="hover:text-primary transition-colors">(503) 555-0142</a><br>
                  <a href="mailto:elena@harmonywellness.com" class="hover:text-primary transition-colors">elena@harmonywellness.com</a>
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg dark:shadow-none dark:border dark:border-slate-700">
          <h3 class="text-xl font-serif font-semibold text-slate-800 dark:text-white mb-6">Schedule a Consultation</h3>
          <form class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">First Name</label>
                <input type="text" class="input" placeholder="Your first name" />
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Last Name</label>
                <input type="text" class="input" placeholder="Your last name" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Email</label>
              <input type="email" class="input" placeholder="your@email.com" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Phone</label>
              <input type="tel" class="input" placeholder="(503) 555-0142" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">What are your primary health concerns?</label>
              <textarea rows="4" class="textarea" placeholder="Tell us about your health goals and what you'd like to address..."></textarea>
            </div>
            <button type="submit" class="btn-primary w-full">
              Request Consultation
              <Icon name="lucide:send" class="w-5 h-5 ml-2" />
            </button>
            <p class="text-xs text-slate-500 dark:text-slate-400 text-center">Your health information is kept strictly confidential.</p>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = trigger.querySelector('.faq-icon');
      
      document.querySelectorAll('.faq-item').forEach(otherItem => {
        if (otherItem !== item) {
          otherItem.querySelector('.faq-content')?.classList.add('hidden');
          otherItem.querySelector('.faq-icon')?.classList.remove('rotate-180');
        }
      });
      
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
