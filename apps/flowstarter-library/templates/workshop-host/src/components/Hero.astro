---
import { frontmatter as hero } from '../../content/hero.md';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroCta {
  text: string;
  href: string;
}

interface HeroContent {
  headline: string;
  subheadline?: string;
  badge?: string;
  cta_primary?: HeroCta;
  cta_secondary?: HeroCta;
  stats?: HeroStat[];
}

const { headline, subheadline, badge, cta_primary, cta_secondary, stats = [] } = hero as HeroContent;
const headlineLines: string[] = headline.split('\n');
---

<section class="relative overflow-hidden px-4 pb-24 pt-28 sm:px-6 lg:px-8">
  <div class="absolute inset-0 bg-[linear-gradient(180deg,#fdfaf4_0%,#f8f3e8_100%)]"></div>
  <div class="relative mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.08fr_0.92fr]">
    <div class="relative z-10 max-w-3xl">
      {badge && (
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border px-5 py-2 text-sm font-medium" style="border-color: color-mix(in srgb, var(--color-primary) 18%, white); background: color-mix(in srgb, var(--color-surface) 75%, transparent); color: var(--color-text);">
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
          <span>{badge}</span>
        </div>
      )}
      <h1 class="relative text-5xl font-light leading-[0.95] text-[var(--color-text)] sm:text-6xl lg:text-7xl" style="font-style: italic;">
        <span class="relative z-10">{headline}</span>
      </h1>
      <div class="mt-3 text-lg italic" style="color: var(--color-accent); font-family: var(--font-heading);">facilitated with clarity, candor, and craft</div>
      {subheadline && (
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[color:var(--color-text-muted)]">{subheadline}</p>
      )}
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        {cta_primary && (
          <a href={cta_primary.href} class="inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold text-white shadow-lg shadow-black/10" style="background: var(--color-primary);">{cta_primary.text}</a>
        )}
        {cta_secondary && (
          <a href={cta_secondary.href} class="inline-flex items-center justify-center rounded-full border px-7 py-4 text-sm font-semibold" style="border-color: color-mix(in srgb, var(--color-primary) 24%, white); color: var(--color-primary); background: color-mix(in srgb, var(--color-surface) 72%, transparent);">{cta_secondary.text}</a>
        )}
      </div>
      <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {stats.map((stat: HeroStat) => (
          <div class="rounded-2xl border border-white/65 bg-white/70 px-5 py-5 backdrop-blur-xl">
            <div class="text-3xl font-bold text-[var(--color-text)]">{stat.value}</div>
            <div class="mt-1 text-sm text-[color:var(--color-text-muted)]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
    <div class="relative min-h-[28rem] lg:min-h-[34rem]">
      <div class="absolute left-0 top-8 h-[76%] w-[84%] rounded-[2.5rem]" style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 16%, white), color-mix(in srgb, var(--color-accent) 18%, white));"></div>
      <div class="absolute right-0 top-0 h-[68%] w-[70%] rounded-[2.5rem] border border-white/50 bg-[linear-gradient(135deg,rgba(255,255,255,0.65),rgba(255,255,255,0.22))] backdrop-blur-md"></div>
      <div class="absolute bottom-0 left-[18%] w-[62%] rounded-[2rem] bg-white/82 px-6 py-6 shadow-xl shadow-black/10">
        <div class="text-sm uppercase tracking-[0.22em] text-[color:var(--color-text-muted)]">Workshop Outcomes</div>
        <div class="mt-3 space-y-3 text-sm text-[var(--color-text)]">
          <div class="flex items-center justify-between"><span>Alignment</span><span>92%</span></div>
          <div class="h-2 rounded-full bg-[color:var(--color-secondary)]"><div class="h-full w-[92%] rounded-full bg-[var(--color-primary)]"></div></div>
          <div class="flex items-center justify-between"><span>Action clarity</span><span>88%</span></div>
          <div class="h-2 rounded-full bg-[color:var(--color-secondary)]"><div class="h-full w-[88%] rounded-full bg-[var(--color-accent)]"></div></div>
        </div>
      </div>
    </div>
  </div>
</section>
