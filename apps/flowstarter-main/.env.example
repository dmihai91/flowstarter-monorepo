# ================================
# SUPABASE CONFIGURATION
# ================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_PROJECT_REF=your-supabase-project-ref-here

# ================================
# CLERK AUTHENTICATION
# ================================
# Get these from: https://dashboard.clerk.com

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-here
CLERK_SECRET_KEY=your-clerk-secret-key-here

# Clerk URLs (customize these for your app)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Supabase JWT Template Name (default: 'supabase')
CLERK_SUPABASE_TEMPLATE=supabase

# ================================
# AI SERVICES
# ================================

# OpenRouter API Key (recommended - unified access to 200+ AI models)
# Get from: https://openrouter.ai/keys
# Provides access to Claude, GPT-4, DeepSeek, Llama, and many more
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenAI API Key (required for DALL-E logo generation and content moderation)
# Get from: https://platform.openai.com/api-keys
# Only used for specialized tasks (image generation, moderation)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# AI Audit Encryption Key (for secure AI event logging)
# Generate a random 32-byte hex string
AI_AUDIT_ENC_KEY=your-random-32-byte-hex-string-here

# ================================
# GODADDY DOMAIN API (Optional)
# ================================
# Get from: https://developer.godaddy.com/
# See docs/GODADDY_API_SETUP.md for setup instructions

GODADDY_API_KEY=your-godaddy-api-key-here
GODADDY_API_SECRET=your-godaddy-api-secret-here
GODADDY_USE_PRODUCTION=false  # Set to 'true' for production environment

# ================================
# UPLOADTHING (File Uploads)
# ================================
# Get from: https://uploadthing.com/dashboard
# See docs/UPLOADTHING_SETUP.md for setup instructions

UPLOADTHING_SECRET=your-uploadthing-secret-here
UPLOADTHING_APP_ID=your-uploadthing-app-id-here

# ================================
# UPSTASH REDIS (Rate Limiting)
# ================================
# Get from: https://console.upstash.com/
# Optional - if not set, rate limiting will be disabled

UPSTASH_REDIS_REST_URL=your-upstash-redis-url-here
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# ================================
# DAYTONA (Code Workspaces)
# ================================
# Get from: https://www.daytona.io/
# Optional - if not set, Daytona features will be disabled

DAYTONA_API_KEY=your-daytona-api-key-here

# ================================
# ANALYTICS & INTEGRATIONS
# ================================

# Google Analytics Measurement ID for Flowstarter app analytics
# Get from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google OAuth Client Credentials (for user Google Analytics integration)
# Get from: https://console.cloud.google.com/apis/credentials
# See docs/GOOGLE_OAUTH_SETUP.md for detailed setup instructions
# Required for users to connect their Google Analytics accounts
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# [DEPRECATED - Use OAuth instead] Google Analytics Service Account (optional)
# Only needed if you want to use service account instead of OAuth
# Get from: https://console.cloud.google.com/
# 1. Enable Google Analytics Data API
# 2. Create service account with Analytics Viewer role
# 3. Download JSON key and paste entire content as single line
GOOGLE_ANALYTICS_CREDENTIALS=

# ================================
# SITE CONFIGURATION
# ================================

# Your site URL (used for redirects, CORS, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel URL (automatically set by Vercel, no need to set manually)
NEXT_PUBLIC_VERCEL_URL=

# ================================
# EDITOR INTEGRATION
# ================================

# Editor app URL (for handoff redirects)
NEXT_PUBLIC_EDITOR_URL=http://localhost:5173

# Handoff secret for secure cross-app communication (generate with: openssl rand -base64 32)
# Can also use TOKEN_ENCRYPTION_KEY if already set
HANDOFF_SECRET=

# ================================
# FEATURE FLAGS
# ================================

# Node Environment (automatically set)
NODE_ENV=development

